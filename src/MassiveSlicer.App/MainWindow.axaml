<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MassiveSlicer.ViewModels"
        xmlns:views="clr-namespace:MassiveSlicer.App.Views"
        x:Class="MassiveSlicer.App.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="False"
        Title="MassiveSlicer"
        Icon="avares://MassiveSlicer.App/Assets/icon.ico"
        Height="900" Width="1440"
        MinHeight="600" MinWidth="900"
        Background="{DynamicResource Bg0}">

    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding Toolbar.UndoCommand}"/>
        <KeyBinding Gesture="Ctrl+Y" Command="{Binding Toolbar.RedoCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+Z" Command="{Binding Toolbar.RedoCommand}"/>
    </Window.KeyBindings>

    <!--
        Root layout: three rows.
          Row 0 — Toolbar (48 px, fixed)
          Row 1 — Main work area (left | viewport | right)
          Row 2 — Bottom dock (status + optional console), full width
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ──────────────────────────────────────────────────── -->
        <views:ToolbarView Grid.Row="0"
                           DataContext="{Binding Toolbar}"/>

        <!-- ── Main area: left panel | viewport | right panel ───────────── -->
        <Grid x:Name="WorkAreaGrid" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="0"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="300" MinWidth="0"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel -->
            <views:LeftPanelView Grid.Column="0"
                                 DataContext="{Binding LeftPanel}"/>

            <GridSplitter Grid.Column="1"
                          Background="{DynamicResource Border0}"/>

            <!-- Viewport — overlays are hosted in ViewportView's VisualLayerManager.OverlayLayer -->
            <views:ViewportView x:Name="Viewport"
                                Grid.Column="2"
                                DataContext="{Binding Viewport}"/>

            <GridSplitter Grid.Column="3"
                          Background="{DynamicResource Border0}"/>

            <!-- Right panel — visibility toggled from code-behind -->
            <views:RightPanelView x:Name="RightPanel"
                                  Grid.Column="4"
                                  DataContext="{Binding RightPanel}"/>
        </Grid>

        <!-- ── Bottom dock: full width under all panels ─────────────────── -->
        <views:BottomLeftDockView Grid.Row="2"
                                  DataContext="{Binding}"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Bottom"/>
    </Grid>

</Window>
