<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ia="https://github.com/projektanker/icons.avalonia"
             xmlns:local="clr-namespace:MassiveSlicer.App.Views"
             xmlns:vm="clr-namespace:MassiveSlicer.ViewModels"
             x:Class="MassiveSlicer.App.Views.Lfam3WorkflowTimelineView"
             x:DataType="vm:ViewportViewModel"
             x:CompileBindings="True"
             Background="Transparent"
             ClipToBounds="False"
             VerticalAlignment="Bottom"
             x:Name="WorkflowRoot">

    <UserControl.Resources>
        <DataTemplate x:Key="PrintParamCardBody" x:DataType="vm:ViewportViewModel">
            <StackPanel Spacing="4">
                <TextBlock Text="Pellet Extruder" Classes="Lfam3WorkflowPhaseSub" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding PrintParamLine1}" FontSize="10" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding PrintParamLine2}" Classes="LabelMuted" FontSize="10" TextWrapping="Wrap"/>
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="VerifyScanParamCardBody" x:DataType="vm:ViewportViewModel">
            <StackPanel Spacing="4">
                <TextBlock Text="Collision check" Classes="Lfam3WorkflowPhaseSub" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding VerifyScanParamLine1}" FontSize="10" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding VerifyScanParamLine2}" Classes="LabelMuted" FontSize="10" TextWrapping="Wrap"/>
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="MillParamCardBody" x:DataType="vm:ViewportViewModel">
            <StackPanel Spacing="4">
                <TextBlock Text="Spindle" Classes="Lfam3WorkflowPhaseSub" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding MillParamLine1}" FontSize="10" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding MillParamLine2}" Classes="LabelMuted" FontSize="10" TextWrapping="Wrap"/>
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="PrePrintScanParamCardBody" x:DataType="vm:ViewportViewModel">
            <StackPanel Spacing="4">
                <TextBlock Text="Scene scan" Classes="Lfam3WorkflowPhaseSub" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding PrePrintScanParamLine1}" FontSize="10" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding PrePrintScanParamLine2}" Classes="LabelMuted" FontSize="10" TextWrapping="Wrap"/>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid VerticalAlignment="Bottom" HorizontalAlignment="Stretch">
    <Border Classes="Lfam3WorkflowPanel" HorizontalAlignment="Stretch" VerticalAlignment="Bottom">
        <StackPanel VerticalAlignment="Bottom" Spacing="0">

            <!-- Expanded body grows upward; track sits directly above the header bar -->
            <StackPanel Spacing="10"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,10"
                        ZIndex="2"
                        ClipToBounds="False"
                        IsVisible="{Binding IsLfam3WorkflowExpanded}">

                <!-- Spacer + negative margin reserves room for floats above the track without shifting rivets -->
                <StackPanel Spacing="0" ClipToBounds="False">
                    <Panel Height="90"
                           Margin="0,0,0,-90"
                           ClipToBounds="False"
                           IsHitTestVisible="False"
                           Background="Transparent"/>
                    <Border Classes="Lfam3WorkflowTrack"
                            Margin="0,-90,0,0"
                            ClipToBounds="False">
                    <Panel ClipToBounds="False">
                    <Grid x:Name="Track3Phase"
                          ColumnDefinitions="28,*,*,*"
                          ColumnSpacing="6"
                          RowDefinitions="56"
                          VerticalAlignment="Center"
                          IsVisible="{Binding !HasPrePrintScanStep}">

                        <Button Grid.Column="0"
                                Classes="Lfam3WorkflowAddStep"
                                Command="{Binding TogglePrePrintScanStepCommand}"
                                ToolTip.Tip="{Binding PrePrintScanToggleTip}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                            <ia:Icon Value="{Binding PrePrintScanToggleIcon}" FontSize="13" Foreground="#59FF0D"/>
                        </Button>

                        <Border Grid.Column="0"
                                Grid.ColumnSpan="4"
                                Classes="Lfam3WorkflowConnector"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0"
                                ZIndex="0"
                                IsHitTestVisible="False"/>
                        <Border Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Classes="Lfam3WorkflowConnector done"
                                VerticalAlignment="Center"
                                Margin="14,0,0,0"
                                ZIndex="0"
                                IsVisible="{Binding IsWorkflowSegment0Complete}"
                                IsHitTestVisible="False"/>
                        <Border Grid.Column="2"
                                Grid.ColumnSpan="2"
                                Classes="Lfam3WorkflowConnector done"
                                VerticalAlignment="Center"
                                ZIndex="0"
                                IsVisible="{Binding IsWorkflowSegment1Complete}"
                                IsHitTestVisible="False"/>

                        <local:Lfam3WorkflowPhaseColumn Grid.Column="1"
                            ToolPanel="{Binding ExtruderToolPanel}"
                            PhaseTitle="PRINT"
                            PhaseToolTip="Print — pellet extruder"
                            PhaseIcon="mdi-printer-3d-nozzle"
                            SelectPhaseCommand="{Binding SelectPrintPhaseCommand}"
                            IsStepActive="{Binding IsPrintStepActive}"
                            IsStepCompleted="{Binding IsPrintStepCompleted}"
                            IsStepPending="{Binding IsPrintStepPending}"
                            IsDetailExpanded="{Binding ExtruderToolPanel.ShowPlayback}"
                            ShowPlayback="{Binding ExtruderToolPanel.ShowPlayback}"
                            DetailContent="{Binding}"
                            DetailTemplate="{StaticResource PrintParamCardBody}"/>

                        <local:Lfam3WorkflowPhaseColumn Grid.Column="2"
                            ToolPanel="{Binding ScannerToolPanel}"
                            PhaseTitle="SCAN"
                            PhaseToolTip="Verify scan — collision check"
                            PhaseIcon="mdi-camera-control"
                            SelectPhaseCommand="{Binding SelectVerifyScanPhaseCommand}"
                            IsStepActive="{Binding IsVerifyScanStepActive}"
                            IsStepCompleted="{Binding IsVerifyScanStepCompleted}"
                            IsStepPending="{Binding IsVerifyScanStepPending}"
                            IsDetailExpanded="{Binding ScannerToolPanel.ShowPlayback}"
                            ShowPlayback="{Binding ScannerToolPanel.ShowPlayback}"
                            DetailContent="{Binding}"
                            DetailTemplate="{StaticResource VerifyScanParamCardBody}"/>

                        <local:Lfam3WorkflowPhaseColumn Grid.Column="3"
                            ToolPanel="{Binding SpindleToolPanel}"
                            PhaseTitle="MILL"
                            PhaseToolTip="Mill — spindle finish"
                            PhaseIcon="mdi-circular-saw"
                            SelectPhaseCommand="{Binding SelectMillPhaseCommand}"
                            IsStepActive="{Binding IsMillStepActive}"
                            IsStepCompleted="{Binding IsMillStepCompleted}"
                            IsStepPending="{Binding IsMillStepPending}"
                            IsDetailExpanded="{Binding SpindleToolPanel.ShowPlayback}"
                            ShowPlayback="{Binding SpindleToolPanel.ShowPlayback}"
                            DetailContent="{Binding}"
                            DetailTemplate="{StaticResource MillParamCardBody}"/>
                    </Grid>

                    <Grid ColumnDefinitions="28,*,*,*,*"
                          ColumnSpacing="6"
                          RowDefinitions="56"
                          VerticalAlignment="Center"
                          IsVisible="{Binding HasPrePrintScanStep}">

                        <Button Grid.Column="0"
                                Classes="Lfam3WorkflowAddStep"
                                Classes.active="{Binding HasPrePrintScanStep}"
                                Command="{Binding TogglePrePrintScanStepCommand}"
                                ToolTip.Tip="{Binding PrePrintScanToggleTip}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                            <ia:Icon Value="{Binding PrePrintScanToggleIcon}" FontSize="13" Foreground="#59FF0D"/>
                        </Button>

                        <Border Grid.Column="0"
                                Grid.ColumnSpan="5"
                                Classes="Lfam3WorkflowConnector"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0"
                                ZIndex="0"
                                IsHitTestVisible="False"/>
                        <Border Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Classes="Lfam3WorkflowConnector done"
                                VerticalAlignment="Center"
                                Margin="14,0,0,0"
                                ZIndex="0"
                                IsVisible="{Binding IsWorkflowSegment0Complete}"
                                IsHitTestVisible="False"/>
                        <Border Grid.Column="2"
                                Grid.ColumnSpan="2"
                                Classes="Lfam3WorkflowConnector done"
                                VerticalAlignment="Center"
                                ZIndex="0"
                                IsVisible="{Binding IsWorkflowSegment1Complete}"
                                IsHitTestVisible="False"/>
                        <Border Grid.Column="3"
                                Grid.ColumnSpan="2"
                                Classes="Lfam3WorkflowConnector done"
                                VerticalAlignment="Center"
                                ZIndex="0"
                                IsVisible="{Binding IsWorkflowSegment2Complete}"
                                IsHitTestVisible="False"/>

                        <local:Lfam3WorkflowPhaseColumn Grid.Column="1"
                            ToolPanel="{Binding ScannerToolPanel}"
                            PhaseTitle="SCAN"
                            PhaseToolTip="Pre-print scan"
                            PhaseIcon="mdi-camera-control"
                            SelectPhaseCommand="{Binding SelectPrePrintScanPhaseCommand}"
                            IsStepActive="{Binding IsPrePrintScanStepActive}"
                            IsStepCompleted="{Binding IsPrePrintScanStepCompleted}"
                            IsStepPending="{Binding IsPrePrintScanStepPending}"
                            IsDetailExpanded="{Binding ScannerToolPanel.ShowPlayback}"
                            ShowPlayback="{Binding ScannerToolPanel.ShowPlayback}"
                            DetailContent="{Binding}"
                            DetailTemplate="{StaticResource PrePrintScanParamCardBody}"/>

                        <local:Lfam3WorkflowPhaseColumn Grid.Column="2"
                            ToolPanel="{Binding ExtruderToolPanel}"
                            PhaseTitle="PRINT"
                            PhaseToolTip="Print — pellet extruder"
                            PhaseIcon="mdi-printer-3d-nozzle"
                            SelectPhaseCommand="{Binding SelectPrintPhaseCommand}"
                            IsStepActive="{Binding IsPrintStepActive}"
                            IsStepCompleted="{Binding IsPrintStepCompleted}"
                            IsStepPending="{Binding IsPrintStepPending}"
                            IsDetailExpanded="{Binding ExtruderToolPanel.ShowPlayback}"
                            ShowPlayback="{Binding ExtruderToolPanel.ShowPlayback}"
                            DetailContent="{Binding}"
                            DetailTemplate="{StaticResource PrintParamCardBody}"/>

                        <local:Lfam3WorkflowPhaseColumn Grid.Column="3"
                            ToolPanel="{Binding ScannerToolPanel}"
                            PhaseTitle="SCAN"
                            PhaseToolTip="Verify scan"
                            PhaseIcon="mdi-camera-control"
                            SelectPhaseCommand="{Binding SelectVerifyScanPhaseCommand}"
                            IsStepActive="{Binding IsVerifyScanStepActive}"
                            IsStepCompleted="{Binding IsVerifyScanStepCompleted}"
                            IsStepPending="{Binding IsVerifyScanStepPending}"
                            IsDetailExpanded="{Binding ScannerToolPanel.ShowPlayback}"
                            ShowPlayback="{Binding ScannerToolPanel.ShowPlayback}"
                            DetailContent="{Binding}"
                            DetailTemplate="{StaticResource VerifyScanParamCardBody}"/>

                        <local:Lfam3WorkflowPhaseColumn Grid.Column="4"
                            ToolPanel="{Binding SpindleToolPanel}"
                            PhaseTitle="MILL"
                            PhaseToolTip="Mill — spindle"
                            PhaseIcon="mdi-circular-saw"
                            SelectPhaseCommand="{Binding SelectMillPhaseCommand}"
                            IsStepActive="{Binding IsMillStepActive}"
                            IsStepCompleted="{Binding IsMillStepCompleted}"
                            IsStepPending="{Binding IsMillStepPending}"
                            IsDetailExpanded="{Binding SpindleToolPanel.ShowPlayback}"
                            ShowPlayback="{Binding SpindleToolPanel.ShowPlayback}"
                            DetailContent="{Binding}"
                            DetailTemplate="{StaticResource MillParamCardBody}"/>
                    </Grid>
                    </Panel>
                    </Border>
                </StackPanel>

                <Border Classes="Lfam3WorkflowSectionDivider"
                        IsVisible="{Binding LiveIo.IsExpanded}"/>
                <ScrollViewer MaxHeight="{Binding Lfam3LiveIoMaxHeight}"
                              VerticalScrollBarVisibility="Auto"
                              IsVisible="{Binding LiveIo.IsExpanded}">
                    <local:Lfam3LiveIoPanelView DataContext="{Binding LiveIo}"/>
                </ScrollViewer>
            </StackPanel>

            <!-- Header bar pinned to the bottom edge of the panel -->
            <Grid ColumnDefinitions="Auto,*,Auto" ZIndex="1">
                <Button Grid.Column="0"
                        Classes="Lfam3WorkflowHeaderBtn"
                        Command="{Binding ToggleLfam3WorkflowCommand}"
                        ToolTip.Tip="{Binding Lfam3WorkflowMinimizeTip}">
                    <ia:Icon Value="{Binding Lfam3WorkflowMinimizeIcon}" FontSize="14" Foreground="#59FF0D"/>
                </Button>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0"
                            IsVisible="{Binding !IsLfam3WorkflowExpanded}">
                    <TextBlock Text="LFAM 3" Classes="LabelMuted" FontSize="10" LetterSpacing="1.2" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Lfam3WorkflowStatusLabel}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="2"
                        Classes="Lfam3LiveIoToggleBar"
                        Classes.expanded="{Binding LiveIo.IsExpanded}"
                        Command="{Binding LiveIo.ToggleExpandedCommand}"
                        IsVisible="{Binding IsLfam3WorkflowExpanded}"
                        ToolTip.Tip="Live I/O monitor">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <ia:Icon Value="{Binding LiveIo.ToggleIcon}" FontSize="14" Foreground="#59FF0D"/>
                        <TextBlock Text="{Binding LiveIo.ToggleLabel}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="#59FF0D"
                                   LetterSpacing="0.6"/>
                    </StackPanel>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
    </Grid>
</UserControl>