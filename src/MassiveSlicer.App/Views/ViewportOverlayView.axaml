<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ia="https://github.com/projektanker/icons.avalonia"
             x:Class="MassiveSlicer.App.Views.ViewportOverlayView"
             x:CompileBindings="False">

    <Grid>

        <!-- Selection toolbar — bottom-left -->
        <Border HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="8"
                Background="{DynamicResource Bg2}"
                BorderBrush="{DynamicResource Border1}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="4">
            <StackPanel Orientation="Horizontal">
                <Button Content="V" Classes="ToolbarButton" ToolTip.Tip="Vertex (1)" Padding="6,4" Margin="0,0,2,0"/>
                <Button Content="E" Classes="ToolbarButton" ToolTip.Tip="Edge (2)"   Padding="6,4" Margin="0,0,2,0"/>
                <Button Content="F" Classes="ToolbarButton" ToolTip.Tip="Face (3)"   Padding="6,4" Margin="0,0,2,0"/>
                <Button Content="O" Classes="ToolbarButton" ToolTip.Tip="Object (4)" Padding="6,4" Margin="0,0,8,0"/>
                <Border Width="1" Background="{DynamicResource Border1}" Margin="0,4"/>
                <Button Classes="ToolbarButton" ToolTip.Tip="Move (G)"   Padding="6,4" Margin="0,0,2,0"
                        Classes.active="{Binding IsMoveActive}"
                        Command="{Binding GizmoMoveCommand}">
                    <ia:Icon Value="mdi-cursor-move" FontSize="14"/>
                </Button>
                <Button Classes="ToolbarButton" ToolTip.Tip="Rotate (R)" Padding="6,4" Margin="0,0,2,0"
                        Classes.active="{Binding IsRotateActive}"
                        Command="{Binding GizmoRotateCommand}">
                    <ia:Icon Value="mdi-rotate-3d-variant" FontSize="14"/>
                </Button>
                <Button Classes="ToolbarButton" ToolTip.Tip="Scale (S)"  Padding="6,4" Margin="0,0,2,0"
                        Classes.active="{Binding IsScaleActive}"
                        Command="{Binding GizmoScaleCommand}">
                    <ia:Icon Value="mdi-arrow-expand-all" FontSize="14"/>
                </Button>
                <Border Width="1" Background="{DynamicResource Border1}" Margin="4,4,0,4"/>
                <Button Classes="ToolbarButton" ToolTip.Tip="Toggle gizmo handles (active = gizmo; inactive = G/R/S mouse transform)" Padding="6,4" Margin="2,0,0,0"
                        Classes.active="{Binding GizmoEnabled}"
                        Command="{Binding GizmoToggleCommand}">
                    <ia:Icon Value="mdi-axis-arrow" FontSize="14"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- Focus overlay — top-left, visible only when an object is selected -->
        <Border IsVisible="{Binding HasSelection}"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="8"
                Background="{DynamicResource Bg2}"
                BorderBrush="{DynamicResource Border1}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="4">
            <StackPanel Orientation="Horizontal">
                <Button Content="Focus"
                        Classes="ToolbarButton"
                        Padding="10,4"
                        Command="{Binding FocusCommand}"
                        ToolTip.Tip="Focus camera on selected object (F)"/>
                <Border Width="1" Background="{DynamicResource Border1}" Margin="3,2"
                        IsVisible="{Binding !IsToolpathSelected}"/>
                <Button Content="Lay on Face"
                        Classes="ToolbarButton"
                        Classes.active="{Binding IsLayFlatMode}"
                        Padding="10,4"
                        Command="{Binding LayFlatCommand}"
                        IsVisible="{Binding !IsToolpathSelected}"
                        ToolTip.Tip="Click a face to align it flat on the build plate (Esc to cancel)"/>
                <Button Content="Drop to Plate"
                        Classes="ToolbarButton"
                        Padding="10,4"
                        Margin="2,0,0,0"
                        Command="{Binding DropToPlateCommand}"
                        IsVisible="{Binding !IsToolpathSelected}"
                        ToolTip.Tip="Translate the object down so its lowest point sits on the build plate"/>
            </StackPanel>
        </Border>

        <!-- Toolpath scrubber — right-center.
             Label lays out at the top of its column and tracks the thumb via RenderTransform,
             so no fixed pixel widths are needed and the slider auto-sizes naturally. -->
        <Grid IsVisible="{Binding IsToolpathSelected}"
              HorizontalAlignment="Right"
              VerticalAlignment="Center"
              Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Floating label — tracks thumb via RenderTransform.Y.
                 The move number is an editable TextBox; typing a new value and
                 pressing Enter or clicking away jumps the slider to that position. -->
            <Border Grid.Column="0"
                    VerticalAlignment="Top"
                    Background="{DynamicResource Bg2}"
                    BorderBrush="{DynamicResource Border1}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="6,3">
                <Border.RenderTransform>
                    <TranslateTransform Y="{Binding ToolpathScrubThumbOffsetY}"/>
                </Border.RenderTransform>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox Text="{Binding ToolpathScrubText}"
                             Classes="ScrubInput"
                             ToolTip.Tip="Type a move number and press Enter"/>
                    <TextBlock Text="{Binding ToolpathScrubMaxLabel}"
                               Classes="Readout"
                               FontSize="10"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Vertical slider box — auto-sized so Avalonia centres the track naturally -->
            <Border Grid.Column="2"
                    Background="{DynamicResource Bg2}"
                    BorderBrush="{DynamicResource Border1}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="4">
                <Grid>
                    <!-- Unfilled rail -->
                    <Rectangle Width="4"
                               Fill="{DynamicResource Border2}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Stretch"
                               Margin="4"/>
                    <!-- Accent fill — grows from the bottom as value increases -->
                    <Rectangle Width="4"
                               Fill="{DynamicResource Accent}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Bottom"
                               Height="{Binding ToolpathScrubFillHeight}"
                               Margin="4"/>
                    <!-- Slider on top — RepeatButtons transparent, thumb remains visible -->
                    <Slider Classes="ScrubSlider"
                            Orientation="Vertical"
                            Height="480"
                            Minimum="0"
                            Maximum="{Binding ToolpathScrubMax}"
                            Value="{Binding ToolpathScrubIndex}"
                            IsSnapToTickEnabled="True"
                            TickFrequency="1"/>
                </Grid>
            </Border>

        </Grid>

        <!-- Toolpath stats — top-right -->
        <Border IsVisible="{Binding HasToolpathStats}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="8"
                Background="{DynamicResource Bg2}"
                BorderBrush="{DynamicResource Border1}"
                BorderThickness="1"
                CornerRadius="4"
                Opacity="0.88"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Time"     Classes="LabelMuted" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding StatsTime}"   Classes="Readout" FontSize="11"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Material" Classes="LabelMuted" FontSize="11" VerticalAlignment="Center" Margin="0,4,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding StatsWeight}" Classes="Readout" FontSize="11" Margin="0,4,0,0"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Cost"     Classes="LabelMuted" FontSize="11" VerticalAlignment="Center" Margin="0,4,0,0"/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding StatsCost}"   Classes="Readout" FontSize="11" Margin="0,4,0,0"/>
            </Grid>
        </Border>

        <!-- Coordinate readout — bottom-right -->
        <Border HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="8"
                Background="{DynamicResource Bg2}"
                BorderBrush="{DynamicResource Border1}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8,4">
            <TextBlock Text="X: 0.0   Y: 0.0   Z: 0.0"
                       Classes="Readout"
                       FontSize="11"/>
        </Border>

    </Grid>

</UserControl>
