<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ia="https://github.com/projektanker/icons.avalonia"
             x:Class="MassiveSlicer.App.Views.ToolbarView"
             x:CompileBindings="False">

    <Border Background="{DynamicResource Bg1}"
            BorderBrush="{DynamicResource Border1}"
            BorderThickness="0,0,0,1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left: brand + file menu ──────────────────────────────────── -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="12,0">
                <TextBlock Text="MASSIVE"
                           FontWeight="Bold" FontSize="14"
                           Foreground="{DynamicResource Accent}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="SLICER"
                           FontWeight="Light" FontSize="14"
                           Foreground="{DynamicResource TextSecondary}"
                           VerticalAlignment="Center"
                           Margin="2,0,12,0"/>

                <Menu Background="Transparent" VerticalAlignment="Center" Margin="0,0,4,0">
                    <MenuItem Header="_File">
                        <MenuItem Header="_Open..."
                                  Command="{Binding OpenWorkspaceCommand}"
                                  InputGesture="Ctrl+O"/>
                        <MenuItem Header="_Save"
                                  Command="{Binding SaveWorkspaceCommand}"
                                  InputGesture="Ctrl+S"/>
                        <MenuItem Header="Save _As..."
                                  Command="{Binding SaveWorkspaceAsCommand}"
                                  InputGesture="Ctrl+Shift+S"/>
                        <Separator/>
                        <MenuItem Header="Import _Model..."
                                  Command="{Binding OpenModelCommand}"/>
                        <MenuItem Header="Import _KRL..."
                                  Command="{Binding ImportKrlCommand}"/>
                        <Separator/>
                        <MenuItem Header="_Preferences..."
                                  Command="{Binding OpenPreferencesCommand}"/>
                    </MenuItem>
                    <MenuItem Header="_Edit">
                        <MenuItem Header="_Undo"
                                  Command="{Binding UndoCommand}"
                                  InputGesture="Ctrl+Z"/>
                        <MenuItem Header="_Redo"
                                  Command="{Binding RedoCommand}"
                                  InputGesture="Ctrl+Y"/>
                    </MenuItem>
                </Menu>
            </StackPanel>

            <!-- ── Right: camera presets + units + toggles ───────────────────── -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center" Margin="0,0,12,0">

                <Button Content="Frame All" Classes="ToolbarButton" Command="{Binding FrameAllCommand}"      Margin="0,0,4,0"/>
                <Button Content="Top"       Classes="ToolbarButton" Command="{Binding TopViewCommand}"       Margin="0,0,4,0"/>
                <Button Content="Front"     Classes="ToolbarButton" Command="{Binding FrontViewCommand}"     Margin="0,0,4,0"/>
                <Button Content="Iso"       Classes="ToolbarButton" Command="{Binding IsometricViewCommand}" Margin="0,0,12,0"/>

                <Button Classes="ToolbarButton" Command="{Binding ToggleConsoleCommand}" ToolTip.Tip="Toggle Console" Margin="0,0,4,0">
                    <ia:Icon Value="mdi-console" FontSize="14"/>
                </Button>
                <Button Classes="ToolbarButton" Command="{Binding ToggleRightPanelCommand}" ToolTip.Tip="Toggle Settings Panel">
                    <ia:Icon Value="mdi-menu" FontSize="14"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>

</UserControl>
