<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MassiveSlicer.ViewModels;assembly=MassiveSlicer.App"
             x:Class="MassiveSlicer.App.Views.ConsoleView"
             x:CompileBindings="False"
             x:DataType="vm:ConsoleViewModel"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <UserControl.Styles>
        <!-- History lines -->
        <Style Selector="SelectableTextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource Bg4}"/>
            <Setter Property="SelectionForegroundBrush" Value="{DynamicResource TextPrimary}"/>
        </Style>
        <Style Selector="SelectableTextBlock.error">
            <Setter Property="Foreground" Value="#ff6b6b"/>
            <Setter Property="SelectionForegroundBrush" Value="{DynamicResource TextPrimary}"/>
        </Style>

        <!-- Autocomplete suggestions — dark row highlight + light text (not green-on-green) -->
        <Style Selector="ListBox.ConsoleSuggestions ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBox.ConsoleSuggestions ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Bg4}"/>
        </Style>
        <Style Selector="ListBox.ConsoleSuggestions ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentMuted}"/>
        </Style>
        <Style Selector="ListBox.ConsoleSuggestions ListBoxItem:pointerover TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>
        <Style Selector="ListBox.ConsoleSuggestions ListBoxItem:selected TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>
        <Style Selector="ListBox.ConsoleSuggestions ListBoxItem:pointerover TextBlock.suggestionName">
            <Setter Property="Foreground" Value="{DynamicResource AccentHover}"/>
        </Style>
        <Style Selector="ListBox.ConsoleSuggestions ListBoxItem:selected TextBlock.suggestionName">
            <Setter Property="Foreground" Value="{DynamicResource AccentHover}"/>
        </Style>
    </UserControl.Styles>

    <!-- Dock input to bottom so history never shares vertical space with the command line. -->
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Height="28"
                Background="{DynamicResource Bg3}"
                BorderBrush="{DynamicResource Border1}"
                BorderThickness="0,0,0,1">
            <TextBlock Text="Console"
                       Foreground="{DynamicResource TextSecondary}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="10,0"/>
        </Border>

        <Border DockPanel.Dock="Bottom"
                x:Name="InputChrome"
                MinHeight="36"
                Background="{DynamicResource Bg3}"
                BorderBrush="{DynamicResource Border1}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="32"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        IsVisible="{Binding HasSuggestions}"
                        Background="{DynamicResource Bg2}"
                        BorderBrush="{DynamicResource Border1}"
                        BorderThickness="0,0,0,1"
                        MaxHeight="140">
                    <ListBox Classes="ConsoleSuggestions"
                             ItemsSource="{Binding Suggestions}"
                             SelectedIndex="{Binding SelectedSuggestionIndex}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0">
                        <ListBox.Resources>
                            <SolidColorBrush x:Key="ThemeControlHighlightMidBrush" Color="#21273a"/>
                            <SolidColorBrush x:Key="ThemeControlHighlightLowBrush" Color="#1e3800"/>
                        </ListBox.Resources>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*,Auto" Margin="8,3">
                                    <TextBlock Grid.Column="0"
                                               Classes="suggestionName"
                                               Text="{Binding Name}"
                                               FontFamily="Consolas,Courier New,monospace"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Accent}"
                                               Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Description}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondary}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Usage}"
                                               FontSize="10"
                                               Foreground="{DynamicResource TextMuted}"
                                               Margin="8,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <Border Grid.Row="1" Padding="8,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="&#x25B6;"
                                   Foreground="{DynamicResource Accent}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>
                        <TextBox x:Name="ConsoleInput"
                                 Grid.Column="1"
                                 Classes="PanelTextBox"
                                 Text="{Binding InputText}"
                                 PlaceholderText="Type a command — try help"
                                 Background="Transparent"
                                 BorderBrush="Transparent"
                                 VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer x:Name="HistoryScroll"
                      VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource Bg1}"
                      Padding="8,6,8,14">
            <ItemsControl ItemsSource="{Binding History}" Margin="0,0,0,6">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ConsoleHistoryEntry">
                        <SelectableTextBlock Text="{Binding DisplayLine}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,3"
                                   FontFamily="Consolas,Courier New,monospace"
                                   FontSize="11"
                                   Classes.error="{Binding IsError}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>