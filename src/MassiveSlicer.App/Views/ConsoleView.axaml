<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MassiveSlicer.App.Views.ConsoleView"
             x:CompileBindings="False"
             Width="420" Height="260">

    <Border Background="{DynamicResource Bg2}"
            BorderBrush="{DynamicResource Border2}"
            BorderThickness="1"
            CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>

            <!-- Title bar (draggable) -->
            <Border Grid.Row="0"
                    x:Name="TitleBar"
                    Background="{DynamicResource Bg3}"
                    CornerRadius="6,6,0,0"
                    Cursor="SizeAll">
                <TextBlock Text="Console"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="10,0"/>
            </Border>

            <!-- Command history -->
            <ScrollViewer Grid.Row="1"
                          x:Name="HistoryScroll"
                          VerticalScrollBarVisibility="Auto"
                          Background="{DynamicResource Bg1}"
                          Padding="8,4">
                <ItemsControl ItemsSource="{Binding History}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run Text="&#x25B6; " Foreground="{DynamicResource Accent}"/>
                                <Run Text="{Binding}" Foreground="{DynamicResource TextPrimary}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Input row -->
            <Border Grid.Row="2"
                    Background="{DynamicResource Bg3}"
                    BorderBrush="{DynamicResource Border1}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,6,6"
                    Padding="8,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="&#x25B6;"
                               Foreground="{DynamicResource Accent}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <TextBox Grid.Column="1"
                             Classes="PanelTextBox"
                             Text="{Binding InputText}"
                             Background="Transparent"
                             BorderBrush="Transparent"
                             VerticalAlignment="Center">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" Command="{Binding SubmitCommand}"/>
                        </TextBox.KeyBindings>
                    </TextBox>
                </Grid>
            </Border>
        </Grid>
    </Border>

</UserControl>
