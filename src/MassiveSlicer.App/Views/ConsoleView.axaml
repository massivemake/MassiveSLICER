<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MassiveSlicer.ViewModels;assembly=MassiveSlicer.App"
             x:Class="MassiveSlicer.App.Views.ConsoleView"
             x:CompileBindings="False"
             x:DataType="vm:ConsoleViewModel"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <UserControl.Styles>
        <Style Selector="TextBlock.error">
            <Setter Property="Foreground" Value="#ff6b6b"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="28"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource Bg3}"
                BorderBrush="{DynamicResource Border1}"
                BorderThickness="0,0,0,1">
            <TextBlock Text="Console"
                       Foreground="{DynamicResource TextSecondary}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="10,0"/>
        </Border>

        <ScrollViewer Grid.Row="1"
                      x:Name="HistoryScroll"
                      VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource Bg1}"
                      Padding="8,4">
            <ItemsControl ItemsSource="{Binding History}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ConsoleHistoryEntry">
                        <TextBlock Text="{Binding DisplayLine}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,2"
                                   Classes.error="{Binding IsError}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="{DynamicResource Bg3}"
                BorderBrush="{DynamicResource Border1}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="32"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        IsVisible="{Binding HasSuggestions}"
                        Background="{DynamicResource Bg2}"
                        BorderBrush="{DynamicResource Border1}"
                        BorderThickness="0,0,0,1"
                        MaxHeight="140">
                    <ListBox ItemsSource="{Binding Suggestions}"
                             SelectedIndex="{Binding SelectedSuggestionIndex}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*,Auto" Margin="8,3">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontFamily="Consolas,Courier New,monospace"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Accent}"
                                               Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Description}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondary}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Usage}"
                                               FontSize="10"
                                               Foreground="{DynamicResource TextMuted}"
                                               Margin="8,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <Border Grid.Row="1" Padding="8,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="&#x25B6;"
                                   Foreground="{DynamicResource Accent}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>
                        <TextBox x:Name="ConsoleInput"
                                 Grid.Column="1"
                                 Classes="PanelTextBox"
                                 Text="{Binding InputText}"
                                 PlaceholderText="Type a command — try help"
                                 Background="Transparent"
                                 BorderBrush="Transparent"
                                 VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>