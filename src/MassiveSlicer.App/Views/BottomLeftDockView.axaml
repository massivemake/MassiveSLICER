<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MassiveSlicer.App.Views"
             x:Class="MassiveSlicer.App.Views.BottomLeftDockView"
             x:CompileBindings="False"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Bottom">

    <Border Background="{DynamicResource Bg2}"
            BorderBrush="{DynamicResource Border2}"
            BorderThickness="0,1,0,0"
            CornerRadius="0"
            ClipToBounds="True"
            HorizontalAlignment="Stretch">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
            </Grid.RowDefinitions>

            <!-- Drag handle — resize console height upward -->
            <Border Grid.Row="0"
                    x:Name="ResizeGrip"
                    Height="6"
                    Background="{DynamicResource Border1}"
                    BorderBrush="{DynamicResource Border2}"
                    BorderThickness="0,0,0,1"
                    Cursor="SizeNorthSouth"
                    IsVisible="{Binding Toolbar.IsConsoleVisible}"
                    ToolTip.Tip="Drag to resize console height">
                <Border Height="2"
                        Width="36"
                        Background="{DynamicResource TextMuted}"
                        Opacity="0.45"
                        CornerRadius="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
            </Border>

            <!-- Console body -->
            <Border Grid.Row="1"
                    Height="{Binding Toolbar.DockedConsoleHeight}"
                    IsVisible="{Binding Toolbar.IsConsoleVisible}"
                    ClipToBounds="True"
                    BorderBrush="{DynamicResource Border1}"
                    BorderThickness="0,0,0,1">
                <local:ConsoleView DataContext="{Binding Console}"/>
            </Border>

            <!-- Status footer -->
            <Border Grid.Row="2"
                    Background="{DynamicResource Bg1}"
                    BorderBrush="{DynamicResource Border1}"
                    BorderThickness="0,1,0,0">
                <StackPanel>
                    <ProgressBar Height="2"
                                 Minimum="0"
                                 Maximum="100"
                                 IsIndeterminate="True"
                                 IsVisible="{Binding StatusBar.IsProgressActive}"
                                 Foreground="{DynamicResource Accent}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 CornerRadius="0"
                                 Margin="0"
                                 Padding="0"/>
                    <Grid Height="24" Margin="8,0">
                        <TextBlock Text="{Binding StatusBar.FileStatus}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"
                                   Classes="LabelMuted"/>
                        <TextBlock Text="{Binding StatusBar.OperationFeedback}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"
                                   Classes="LabelMuted"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>