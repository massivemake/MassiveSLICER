<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ia="https://github.com/projektanker/icons.avalonia"
             xmlns:vm="clr-namespace:MassiveSlicer.ViewModels"
             x:Class="MassiveSlicer.App.Views.Lfam3ToolChangePanelView"
             x:DataType="vm:ToolChangePanelBinding"
             x:CompileBindings="True"
             Background="Transparent">

    <StackPanel Spacing="6">

        <TextBlock Text="{Binding ToolHeader}"
                   FontSize="10"
                   FontWeight="Bold"
                   Foreground="#e8eaef"
                   LetterSpacing="1.2"/>

        <!-- Pick + run caret | Deposit + run caret -->
        <Grid ColumnDefinitions="*,Auto,6,*,Auto" ColumnSpacing="2">
            <Button Grid.Column="0"
                    Classes="Lfam3SeqBtn pick"
                    Classes.active="{Binding IsPickActive}"
                    Command="{Binding PickCommand}"
                    HorizontalAlignment="Stretch"
                    Content="Pick"/>
            <Button Grid.Column="1"
                    Classes="Lfam3SeqRunCaret"
                    Command="{Binding RunPickCommand}"
                    IsEnabled="False"
                    ToolTip.Tip="Run Pick program on the robot (coming soon)">
                <ia:Icon Value="mdi-play" FontSize="12" Foreground="#f59e0b"/>
            </Button>

            <Button Grid.Column="3"
                    Classes="Lfam3SeqBtn deposit"
                    Classes.active="{Binding IsDepositActive}"
                    Command="{Binding DepositCommand}"
                    HorizontalAlignment="Stretch"
                    Content="Deposit"/>
            <Button Grid.Column="4"
                    Classes="Lfam3SeqRunCaret"
                    Command="{Binding RunDepositCommand}"
                    IsEnabled="False"
                    ToolTip.Tip="Run Deposit program on the robot (coming soon)">
                <ia:Icon Value="mdi-play" FontSize="12" Foreground="#f59e0b"/>
            </Button>
        </Grid>

        <!-- Path playback (MassiveCONNECT-style) — visible when this tool's sequence is active -->
        <StackPanel Spacing="4" IsVisible="{Binding ShowPlayback}">

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <Button Grid.Column="0"
                        Classes="Lfam3SeqPlayBtn"
                        Command="{Binding TogglePlaybackCommand}"
                        ToolTip.Tip="Play / pause simulation"
                        Width="30" Height="30"
                        Padding="0">
                    <ia:Icon Value="{Binding PlaybackToggleIcon}" FontSize="14" Foreground="#e8eaef"/>
                </Button>
                <Slider Grid.Column="1"
                        Minimum="0"
                        Maximum="1000"
                        Value="{Binding ScrubValue, Mode=TwoWay}"
                        VerticalAlignment="Center"
                        Classes="Lfam3SeqScrub"/>
            </Grid>

            <TextBlock Text="{Binding StepText}"
                       FontSize="11"
                       Foreground="#e8eaef"
                       TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="3">
                    <TextBlock Text="—" Classes="Lfam3SeqLegendLin dash" FontSize="10"/>
                    <TextBlock Text="LIN (linear)" Classes="Lfam3SeqLegendLin" FontSize="10"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="3">
                    <TextBlock Text="—" Classes="Lfam3SeqLegendPtp dash" FontSize="10"/>
                    <TextBlock Text="PTP (joint)" Classes="Lfam3SeqLegendPtp" FontSize="10"/>
                </StackPanel>
            </StackPanel>

            <TextBlock Text="Click a waypoint marker to inspect / edit its pose"
                       FontSize="10"
                       Foreground="#6b7280"
                       FontStyle="Italic"/>
        </StackPanel>

    </StackPanel>
</UserControl>