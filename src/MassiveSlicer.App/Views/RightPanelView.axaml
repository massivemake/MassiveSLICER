<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ia="https://github.com/projektanker/icons.avalonia"
             x:Class="MassiveSlicer.App.Views.RightPanelView"
             x:CompileBindings="False">

    <Border Background="{DynamicResource Bg2}"
            BorderBrush="{DynamicResource Border1}"
            BorderThickness="1,0,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tab bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource Bg3}"
                    BorderBrush="{DynamicResource Border1}"
                    BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal">
                    <Button Content="ADDITIVE"    Classes="TabButton" Classes.active="{Binding IsAdditiveTab}"    Command="{Binding ShowAdditiveCommand}"    IsVisible="{Binding ShowAdditiveTabButton}"/>
                    <Button Content="SCAN"        Classes="TabButton" Classes.active="{Binding IsScanTab}"        Command="{Binding ShowScanCommand}"        IsVisible="{Binding ShowScanTabButton}"/>
                    <Button Content="SUBTRACTIVE" Classes="TabButton" Classes.active="{Binding IsSubtractiveTab}" Command="{Binding ShowSubtractiveCommand}" IsVisible="{Binding ShowSubtractiveTabButton}"/>
                    <Button Content="TOOLPATH"    Classes="TabButton" Classes.active="{Binding IsToolpathTab}"    Command="{Binding ShowToolpathCommand}"    IsVisible="{Binding ShowToolpathTabButton}"/>
                </StackPanel>
            </Border>

            <!-- ADDITIVE tab -->
            <Grid Grid.Row="1" IsVisible="{Binding IsAdditiveTab}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Method + slicing mode -->
                <StackPanel Grid.Row="0" Margin="8,8,8,4" Spacing="4">
                    <ComboBox HorizontalAlignment="Stretch"
                              ItemsSource="{Binding Additive.AvailableMethodNames}"
                              SelectedItem="{Binding Additive.MethodDisplayName, Mode=TwoWay}"/>
                    <Grid ColumnDefinitions="*,Auto"
                          IsVisible="{Binding Additive.ShowSlicingMode}">
                        <TextBlock Grid.Column="0" Text="Slicing mode" VerticalAlignment="Center" Classes="LabelMuted"/>
                        <ComboBox  Grid.Column="1"
                                   ItemsSource="{Binding Additive.SlicingModeOptions}"
                                   SelectedItem="{Binding Additive.SlicingMode, Mode=TwoWay}"
                                   Width="100" FontSize="11"
                                   ToolTip.Tip="Normal: solid volume with shells and infill. Surface: cladding/boundary paths on mesh intersections; tool stays vertical unless Overhang orientation is enabled."/>
                    </Grid>
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="{DynamicResource Bg2}">
                <StackPanel Margin="0,4,0,8">

                    <!-- MATERIAL -->
                    <Expander Classes="SectionExpander" Header="MATERIAL" IsExpanded="False">
                        <StackPanel Margin="0,0,0,6">
                            <Grid Margin="8,2,8,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,4,0"
                                          PlaceholderText="No preset selected"
                                          ItemsSource="{Binding Additive.MaterialPresets}"
                                          SelectedIndex="{Binding Additive.SelectedPresetIndex, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button Grid.Column="1"
                                        Classes="ToolbarButton"
                                        Padding="8,2"
                                        Margin="0,0,2,0"
                                        Click="OnEditMaterialClicked"
                                        IsEnabled="{Binding Additive.HasSelectedPreset}"
                                        ToolTip.Tip="Edit selected material preset">
                                    <ia:Icon Value="mdi-pencil" FontSize="14"/>
                                </Button>
                                <Button Grid.Column="2"
                                        Classes="ToolbarButton"
                                        Padding="8,2"
                                        Click="OnAddMaterialClicked"
                                        ToolTip.Tip="Add new material preset">
                                    <ia:Icon Value="mdi-plus" FontSize="16"/>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Expander>

                    <!-- GEOMETRY -->
                    <Expander Classes="SectionExpander" Header="GEOMETRY" IsExpanded="False">
                        <StackPanel Margin="0,2,0,6">
                            <Grid Margin="8,2,8,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Layer height (mm)" VerticalAlignment="Center" Classes="LabelMuted"
                                           ToolTip.Tip="In adaptive mode this becomes the maximum layer height"/>
                                <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Additive.LayerHeight}"/>
                            </Grid>

                            <Grid Margin="8,2,8,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Bead width (mm)" VerticalAlignment="Center" Classes="LabelMuted"/>
                                <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Additive.BeadWidth}"/>
                            </Grid>

                            <Grid Margin="8,2,8,4" IsVisible="{Binding Additive.ShowTiltAngle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="56"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Y tilt (°)" Classes="LabelMuted" VerticalAlignment="Center"/>
                                <Slider    Grid.Column="1" Minimum="-89" Maximum="89"
                                           Value="{Binding Additive.TiltAngle, Mode=TwoWay}"
                                           VerticalAlignment="Center"/>
                                <TextBox   Grid.Column="2" Classes="PanelTextBox"
                                           Text="{Binding Additive.TiltAngle, Mode=TwoWay, StringFormat={}{0:F1}}"
                                           TextAlignment="Right" Padding="4,2" VerticalContentAlignment="Center"/>
                            </Grid>

                            <Grid Margin="8,2,8,4" IsVisible="{Binding Additive.ShowTiltAngle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="56"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="X tilt (°)" Classes="LabelMuted" VerticalAlignment="Center"/>
                                <Slider    Grid.Column="1" Minimum="-89" Maximum="89"
                                           Value="{Binding Additive.TiltAngleX, Mode=TwoWay}"
                                           VerticalAlignment="Center"/>
                                <TextBox   Grid.Column="2" Classes="PanelTextBox"
                                           Text="{Binding Additive.TiltAngleX, Mode=TwoWay, StringFormat={}{0:F1}}"
                                           TextAlignment="Right" Padding="4,2" VerticalContentAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Expander>

                    <!-- SEAM -->
                    <Expander Classes="SectionExpander" Header="SEAM" IsExpanded="False"
                              IsVisible="{Binding Additive.ShowContourOffsetOption}">
                        <StackPanel Margin="0,2,0,6">
                            <Grid ColumnDefinitions="*,Auto" Margin="8,2,8,4">
                                <TextBlock Grid.Column="0" Text="Mode" VerticalAlignment="Center" Classes="LabelMuted"/>
                                <ComboBox  Grid.Column="1"
                                           ItemsSource="{Binding Additive.SeamModeOptions}"
                                           SelectedItem="{Binding Additive.SeamMode, Mode=TwoWay}"
                                           Width="90" FontSize="11"/>
                            </Grid>

                            <TextBlock Text="LOCATION" Classes="LabelMuted" FontSize="10" Margin="8,6,8,2" LetterSpacing="1"/>

                            <Grid ColumnDefinitions="*,Auto" Margin="8,2,8,4">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="Seam position guides" Classes="LabelMuted"/>
                                    <TextBlock Text="{Binding Additive.SeamGuideSummary}" FontSize="10" Opacity="0.7"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="Edit"
                                        Classes="ToolbarButton"
                                        Padding="10,4"
                                        Command="{Binding Additive.OpenSeamEditorCommand}"
                                        ToolTip.Tip="Place points on the model. Seams start at the contour point closest to each guide."/>
                            </Grid>

                            <CheckBox Content="Overhang orientation"
                                      IsChecked="{Binding Additive.OverhangOrientation, Mode=TwoWay}"
                                      Margin="8,2,8,2"/>

                            <Grid ColumnDefinitions="*,Auto"
                                  Margin="8,2,8,4"
                                  IsVisible="{Binding Additive.ShowOverhangTilt}">
                                <TextBlock Grid.Column="0" Text="Max tilt (°)" VerticalAlignment="Center" Classes="LabelMuted" FontSize="11"/>
                                <NumericUpDown Grid.Column="1"
                                              Value="{Binding Additive.MaxOverhangTiltDeg, Mode=TwoWay}"
                                              Minimum="0" Maximum="89" Increment="5"
                                              FormatString="F0" Width="80" FontSize="11"/>
                            </Grid>

                            <CheckBox Content="Disable contour offset"
                                      IsChecked="{Binding Additive.DisableContourOffset, Mode=TwoWay}"
                                      Margin="8,4,8,2"
                                      ToolTip.Tip="Disables offsetting contours by bead width / 2. The print line treats the surface as the center line, adding extra material on the outside. Useful for prints requiring finish milling."/>
                        </StackPanel>
                    </Expander>

                    <!-- MOTION -->
                    <Expander Classes="SectionExpander" Header="MOTION" IsExpanded="False">
                        <StackPanel Margin="0,2,0,6">
                            <Grid Margin="8,2,8,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Print speed (mm/s)" VerticalAlignment="Center" Classes="LabelMuted"/>
                                <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Additive.PrintSpeed}"/>
                            </Grid>

                            <Grid Margin="8,2,8,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Travel speed (mm/s)" VerticalAlignment="Center" Classes="LabelMuted"/>
                                <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Additive.TravelSpeed}"/>
                            </Grid>
                        </StackPanel>
                    </Expander>

                    <!-- MOVEMENT -->
                    <Expander Classes="SectionExpander" Header="MOVEMENT" IsExpanded="False">
                        <StackPanel Margin="0,2,0,6">
                            <Grid Margin="8,2,8,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Z hop (mm)" VerticalAlignment="Center" Classes="LabelMuted"
                                           ToolTip.Tip="Vertical lift on travel moves. 0 = no hop."/>
                                <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Additive.ZHopMm}"/>
                            </Grid>

                            <TextBlock Text="Wipe" Classes="LabelMuted" Margin="8,4,8,2"/>
                            <ComboBox Margin="8,0,8,4" HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding Additive.WipeModeOptions}"
                                      SelectedItem="{Binding Additive.WipeModeDisplay, Mode=TwoWay}"
                                      ToolTip.Tip="Retrace = wipe back over the last extrusion. Same-Direction = continue forward past the travel point for the wipe length."/>

                            <Grid Margin="8,2,8,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Wipe length (mm)" VerticalAlignment="Center" Classes="LabelMuted"/>
                                <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Additive.WipeLengthMm}"/>
                            </Grid>

                            <Grid Margin="8,2,8,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Wipe ramp (mm)" VerticalAlignment="Center" Classes="LabelMuted"
                                           ToolTip.Tip="Positive: last N mm of wipe length ramps RPM to zero. Negative: extend |N| mm past wipe length with squeeze ramp (e.g. 35 length, -1.5 ramp)."/>
                                <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Additive.WipeRampMm}"/>
                            </Grid>

                            <Grid Margin="8,2,8,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Wipe speed (mm/s)" VerticalAlignment="Center" Classes="LabelMuted"
                                           ToolTip.Tip="Linear speed for wipe extrusion moves. Can differ from travel speed."/>
                                <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Additive.WipeSpeed}"/>
                            </Grid>

                            <Grid Margin="8,2,8,4" ColumnDefinitions="*,80">
                                <TextBlock Grid.Column="0" Text="Start wait (s)" VerticalAlignment="Center" Classes="LabelMuted"
                                           ToolTip.Tip="Pause after first RPM-on before the first extrusion move."/>
                                <NumericUpDown Grid.Column="1"
                                               Value="{Binding Additive.ExtrusionStartWaitSec, Mode=TwoWay}"
                                               Minimum="0" Maximum="60" Increment="0.5"
                                               FormatString="F1" FontSize="11"/>
                            </Grid>

                            <Grid Margin="8,2,8,4" ColumnDefinitions="*,80">
                                <TextBlock Grid.Column="0" Text="Resume wait (s)" VerticalAlignment="Center" Classes="LabelMuted"
                                           ToolTip.Tip="Pause after each travel before the next extrusion move — lets lagging extrusion catch up."/>
                                <NumericUpDown Grid.Column="1"
                                               Value="{Binding Additive.ExtrusionResumeWaitSec, Mode=TwoWay}"
                                               Minimum="0" Maximum="60" Increment="0.5"
                                               FormatString="F1" FontSize="11"/>
                            </Grid>

                            <TextBlock Text="Post-travel ramp" Classes="LabelMuted" Margin="8,6,8,2"/>
                            <CheckBox Content="Ramp speed + RPM after travel"
                                      Margin="8,0,8,4"
                                      IsChecked="{Binding Additive.ResumeRampEnabled, Mode=TwoWay}"
                                      FontSize="11"
                                      ToolTip.Tip="After each travel, start extrusion at low speed/RPM and step up over a set distance before reaching full print speed."/>

                            <Grid Margin="8,2,8,4" IsVisible="{Binding Additive.ResumeRampEnabled}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Ramp start speed (mm/s)" VerticalAlignment="Center" Classes="LabelMuted"/>
                                <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Additive.ResumeRampStartSpeed}"/>
                            </Grid>
                            <Grid Margin="8,2,8,4" IsVisible="{Binding Additive.ResumeRampEnabled}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Ramp start RPM (%)" VerticalAlignment="Center" Classes="LabelMuted"/>
                                <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Additive.ResumeRampStartRpmPercent}"/>
                            </Grid>
                            <Grid Margin="8,2,8,4" IsVisible="{Binding Additive.ResumeRampEnabled}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Ramp distance (mm)" VerticalAlignment="Center" Classes="LabelMuted"
                                           ToolTip.Tip="Total path length over which speed and RPM step up. 609.6 mm ≈ 2 ft."/>
                                <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Additive.ResumeRampDistanceMm}"/>
                            </Grid>
                            <Grid Margin="8,2,8,4" IsVisible="{Binding Additive.ResumeRampEnabled}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Ramp steps" VerticalAlignment="Center" Classes="LabelMuted"/>
                                <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Additive.ResumeRampSteps}"/>
                            </Grid>
                        </StackPanel>
                    </Expander>

                    <!-- KRC4 -->
                    <Expander Classes="SectionExpander" Header="KRC4" IsExpanded="False">
                        <StackPanel Margin="0,2,0,6">
                            <Grid Margin="8,2,8,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="TOOL_DATA #" VerticalAlignment="Center" Classes="LabelMuted"/>
                                <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Additive.ToolDataIndex}"/>
                            </Grid>

                            <Grid Margin="8,2,8,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="BASE_DATA #" VerticalAlignment="Center" Classes="LabelMuted"/>
                                <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Additive.BaseDataIndex}"/>
                            </Grid>
                        </StackPanel>
                    </Expander>

                    <!-- EFFECTS -->
                    <Expander Classes="SectionExpander" Header="EFFECTS" IsExpanded="False">
                        <StackPanel Margin="0,2,0,6">

                            <!-- Adaptive layer height -->
                            <CheckBox Margin="8,2,8,4"
                                      Content="Adaptive layer height"
                                      FontSize="11"
                                      IsChecked="{Binding Additive.AdaptiveLayerHeight}"
                                      IsVisible="{Binding Additive.ShowAdaptiveLayerHeight}"
                                      ToolTip.Tip="Vary layer thickness based on surface slope — thin layers on gentle slopes, thick on steep faces. Enables layer preview shading."/>

                            <Grid Margin="8,2,8,4" IsVisible="{Binding Additive.ShowAdaptiveControls}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Min layer height (mm)" VerticalAlignment="Center" Classes="LabelMuted"/>
                                <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Additive.MinLayerHeight}"/>
                            </Grid>

                            <Grid Margin="8,2,8,8" IsVisible="{Binding Additive.ShowAdaptiveControls}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Fine" Classes="LabelMuted" FontSize="10"
                                           VerticalAlignment="Center" Margin="8,0,4,0"/>
                                <Slider    Grid.Column="1" Minimum="0" Maximum="1" TickFrequency="0.01"
                                           Value="{Binding Additive.AdaptiveQuality, Mode=TwoWay}"
                                           VerticalAlignment="Center"
                                           ToolTip.Tip="0 = finest detail (thinnest layers on slopes), 1 = fastest (thickest layers allowed)"/>
                                <TextBlock Grid.Column="2" Text="Coarse" Classes="LabelMuted" FontSize="10"
                                           VerticalAlignment="Center" Margin="4,0,8,0"/>
                            </Grid>

                            <!-- Wave -->
                            <Grid Margin="8,2,8,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Wave" VerticalAlignment="Center" Classes="LabelMuted"/>
                                <ComboBox  Grid.Column="1" HorizontalAlignment="Stretch"
                                           ItemsSource="{Binding Additive.WaveEffectOptions}"
                                           SelectedItem="{Binding Additive.WaveEffect, Mode=TwoWay}"/>
                            </Grid>

                            <StackPanel IsVisible="{Binding Additive.ShowWaveControls}">
                                <Grid Margin="8,2,8,4" IsVisible="{Binding Additive.ShowSingleAmplitude}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Amplitude (mm)" VerticalAlignment="Center" Classes="LabelMuted"
                                               ToolTip.Tip="Peak displacement — how far the path swings left/right of the original line."/>
                                    <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Additive.WaveAmplitude}"/>
                                </Grid>

                                <Grid Margin="8,2,8,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Frequency" VerticalAlignment="Center" Classes="LabelMuted"
                                               ToolTip.Tip="Wavelength: wave density set by mm per cycle. Cycles: fixed number of waves per layer — adapts to perimeter so vases and tapered forms stay visually consistent."/>
                                    <ComboBox  Grid.Column="1" HorizontalAlignment="Stretch"
                                               ItemsSource="{Binding Additive.WaveFrequencyModeOptions}"
                                               SelectedItem="{Binding Additive.WaveFrequencyMode, Mode=TwoWay}"/>
                                </Grid>

                                <Grid Margin="8,2,8,4" IsVisible="{Binding Additive.ShowSingleWavelength}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Wavelength (mm)" VerticalAlignment="Center" Classes="LabelMuted"
                                               ToolTip.Tip="Length of one complete wave cycle along the toolpath."/>
                                    <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Additive.WaveWavelength}"/>
                                </Grid>

                                <Grid Margin="8,2,8,4" IsVisible="{Binding Additive.ShowCyclesInput}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Cycles per layer" VerticalAlignment="Center" Classes="LabelMuted"
                                               ToolTip.Tip="Number of complete wave cycles per contour. The wave scales with the perimeter so every layer has exactly this many waves."/>
                                    <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Additive.WaveCycles}"/>
                                </Grid>

                                <Grid Margin="8,2,8,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="56"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Shape" Classes="LabelMuted" VerticalAlignment="Center"
                                               ToolTip.Tip="1.0 = full waveform. Lower values clip peaks toward a square/trapezoidal wave."/>
                                    <Slider    Grid.Column="1" Minimum="0.01" Maximum="1.0"
                                               Value="{Binding Additive.WaveShape, Mode=TwoWay}"
                                               VerticalAlignment="Center"/>
                                    <TextBox   Grid.Column="2" Classes="PanelTextBox"
                                               Text="{Binding Additive.WaveShape, Mode=TwoWay, StringFormat={}{0:F2}}"
                                               TextAlignment="Right" Padding="4,2" VerticalContentAlignment="Center"/>
                                </Grid>

                                <Grid Margin="8,2,8,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="56"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Stagger" Classes="LabelMuted" VerticalAlignment="Center"
                                               ToolTip.Tip="Phase offset per layer as a fraction of one cycle. 0 = all layers identical, 0.5 = consecutive layers alternate peak↔valley."/>
                                    <Slider    Grid.Column="1" Minimum="0.0" Maximum="1.0"
                                               Value="{Binding Additive.WaveStagger, Mode=TwoWay}"
                                               VerticalAlignment="Center"/>
                                    <TextBox   Grid.Column="2" Classes="PanelTextBox"
                                               Text="{Binding Additive.WaveStagger, Mode=TwoWay, StringFormat={}{0:F2}}"
                                               TextAlignment="Right" Padding="4,2" VerticalContentAlignment="Center"/>
                                </Grid>

                                <CheckBox Content="Gradient"
                                          IsChecked="{Binding Additive.WaveGradient, Mode=TwoWay}"
                                          Margin="8,4,8,4"
                                          ToolTip.Tip="Interpolate amplitude and wavelength linearly from bottom to top of the toolpath."/>

                                <StackPanel IsVisible="{Binding Additive.ShowWaveGradientControls}">
                                    <Grid Margin="8,2,8,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="72"/>
                                            <ColumnDefinition Width="14"/>
                                            <ColumnDefinition Width="72"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Amplitude (mm)" VerticalAlignment="Center" Classes="LabelMuted"
                                                   ToolTip.Tip="Peak displacement at the bottom and top of the toolpath."/>
                                        <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Additive.WaveAmplitudeBottom, Mode=TwoWay}"
                                                   ToolTip.Tip="Bottom (zMin)"/>
                                        <TextBlock Grid.Column="2" Text="→" HorizontalAlignment="Center" VerticalAlignment="Center" Classes="LabelMuted"/>
                                        <TextBox   Grid.Column="3" Classes="PanelTextBox" Text="{Binding Additive.WaveAmplitudeTop, Mode=TwoWay}"
                                                   ToolTip.Tip="Top (zMax)"/>
                                    </Grid>

                                    <Grid Margin="8,2,8,4" IsVisible="{Binding Additive.ShowGradientWavelength}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="72"/>
                                            <ColumnDefinition Width="14"/>
                                            <ColumnDefinition Width="72"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Wavelength (mm)" VerticalAlignment="Center" Classes="LabelMuted"
                                                   ToolTip.Tip="Wave cycle length at the bottom and top of the toolpath."/>
                                        <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Additive.WaveWavelengthBottom, Mode=TwoWay}"
                                                   ToolTip.Tip="Bottom (zMin)"/>
                                        <TextBlock Grid.Column="2" Text="→" HorizontalAlignment="Center" VerticalAlignment="Center" Classes="LabelMuted"/>
                                        <TextBox   Grid.Column="3" Classes="PanelTextBox" Text="{Binding Additive.WaveWavelengthTop, Mode=TwoWay}"
                                                   ToolTip.Tip="Top (zMax)"/>
                                    </Grid>

                                    <Grid Margin="8,2,8,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="52"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="56"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Center" Classes="LabelMuted" VerticalAlignment="Center"
                                                   ToolTip.Tip="Shifts the gradient midpoint along the height axis. 0.5 = linear. Lower values compress the gradient toward the bottom; higher values toward the top."/>
                                        <Slider    Grid.Column="1" Minimum="0.001" Maximum="0.999"
                                                   Value="{Binding Additive.WaveGradientCenter, Mode=TwoWay}"
                                                   VerticalAlignment="Center"/>
                                        <TextBox   Grid.Column="2" Classes="PanelTextBox"
                                                   Text="{Binding Additive.WaveGradientCenter, Mode=TwoWay, StringFormat={}{0:F2}}"
                                                   TextAlignment="Right" Padding="4,2" VerticalContentAlignment="Center"/>
                                    </Grid>

                                    <Grid Margin="8,2,8,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Curve" VerticalAlignment="Center" Classes="LabelMuted"
                                                   ToolTip.Tip="Easing applied to the gradient. Linear = uniform rate. Smooth = slow at both ends. Ease In = slow start. Ease Out = slow finish."/>
                                        <ComboBox  Grid.Column="1" HorizontalAlignment="Stretch"
                                                   ItemsSource="{Binding Additive.WaveGradientCurveOptions}"
                                                   SelectedItem="{Binding Additive.WaveGradientCurve, Mode=TwoWay}"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <!-- FILL PATTERN -->
                    <Expander Classes="SectionExpander" Header="FILL PATTERN" IsExpanded="False">
                        <StackPanel Margin="0,2,0,6">

                            <Grid Margin="8,2,8,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Pattern" VerticalAlignment="Center" Classes="LabelMuted"
                                           ToolTip.Tip="Replaces shell contours with a continuous infill pattern. None = emit shells as normal."/>
                                <ComboBox  Grid.Column="1" HorizontalAlignment="Stretch"
                                           ItemsSource="{Binding Additive.InfillPatternOptions}"
                                           SelectedItem="{Binding Additive.InfillPattern, Mode=TwoWay}"/>
                            </Grid>

                            <StackPanel IsVisible="{Binding Additive.ShowInfillControls}">

                                <Grid Margin="8,2,8,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Spacing (mm)" VerticalAlignment="Center" Classes="LabelMuted"
                                               ToolTip.Tip="Centre-to-centre distance between infill lines in mm. Leave 0 to use the bead width."/>
                                    <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Additive.InfillSpacingMm}"/>
                                </Grid>

                                <Grid Margin="8,2,8,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Angle (°)" VerticalAlignment="Center" Classes="LabelMuted"
                                               ToolTip.Tip="Base angle of infill lines in degrees. 0 = parallel to X axis. Grid rotates +90° every layer; Triangle rotates +60° every layer."/>
                                    <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Additive.InfillAngleDeg}"/>
                                </Grid>

                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <Button Content="Generate Slice"
                            Classes="PrimaryButton"
                            HorizontalAlignment="Stretch"
                            Margin="8,8,8,4"
                            Command="{Binding $parent[Window].DataContext.Viewport.SliceCommand}"/>
                </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- SCAN tab -->
            <Grid Grid.Row="1" IsVisible="{Binding IsScanTab}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- SCAN sub-tab bar -->
                <Border Grid.Row="0"
                        Background="{DynamicResource Bg3}"
                        BorderBrush="{DynamicResource Border1}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="CAPTURE"  Classes="TabButton" Classes.active="{Binding Scan.IsCaptureSubTab}"     Command="{Binding Scan.ShowCaptureCommand}"/>
                        <Button Content="SETTINGS" Classes="TabButton" Classes.active="{Binding Scan.IsCalibrationSubTab}" Command="{Binding Scan.ShowCalibrationCommand}"/>
                    </StackPanel>
                </Border>

                <!-- CAPTURE sub-tab -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="{DynamicResource Bg2}"
                              IsVisible="{Binding Scan.IsCaptureSubTab}">
                    <StackPanel Margin="0,8">

                        <!-- CAMERA -->
                        <Expander Classes="SectionExpander" Header="CAMERA" IsExpanded="False">
                            <StackPanel Margin="0,2,0,6">
                                <Grid Margin="8,2,8,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Camera IP" VerticalAlignment="Center" Classes="LabelMuted"
                                               ToolTip.Tip="Address of the Zivid camera on the cell network"/>
                                    <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Scan.CameraIp}"/>
                                </Grid>

                                <Button Content="Test Scan"
                                        Classes="PrimaryButton"
                                        HorizontalAlignment="Stretch"
                                        Margin="8,8,8,2"
                                        Command="{Binding Scan.TestScanCommand}"
                                        ToolTip.Tip="Capture a single frame from the Zivid camera and add it to the scene"/>
                                <TextBlock Text="{Binding Scan.ScanStatus}"
                                           Classes="LabelMuted" Margin="8,2,8,4" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Expander>

                        <!-- OUTPUT -->
                        <Expander Classes="SectionExpander" Header="OUTPUT" IsExpanded="False">
                            <StackPanel Margin="0,2,0,6">
                                <TextBlock Text="Scan output directory" Classes="LabelMuted" Margin="8,2,8,2"
                                           ToolTip.Tip="Captured scans (.zdf / .ply) are written here. Relative paths resolve against the application directory."/>
                                <TextBox Classes="PanelTextBox" Margin="8,0,8,4" Text="{Binding Scan.OutputDirectory}"/>
                            </StackPanel>
                        </Expander>

                    </StackPanel>
                </ScrollViewer>

                <!-- SETTINGS sub-tab (hand-eye calibration) -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="{DynamicResource Bg2}"
                              IsVisible="{Binding Scan.IsCalibrationSubTab}">
                    <StackPanel Margin="0,8">

                        <Expander Classes="SectionExpander" Header="HAND-EYE CALIBRATION" IsExpanded="False">
                            <StackPanel Margin="0,2,0,6">

                                <TextBlock Classes="LabelMuted" Margin="8,4,8,8" TextWrapping="Wrap"
                                           Text="Place the calibration board on the print bed. Move the robot to several distinct positions and add a pose at each. Aim for ≥ 10 poses with varied orientations."/>

                                <!-- Pose count -->
                                <TextBlock Text="{Binding Scan.Calibration.PoseCountLabel}"
                                           Classes="LabelMuted" Margin="8,4,8,2" FontWeight="SemiBold"/>

                                <!-- Add Pose / Clear All -->
                                <Grid Margin="8,4,8,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="Add Pose"
                                            Classes="PrimaryButton" HorizontalAlignment="Stretch"
                                            Command="{Binding Scan.Calibration.AddPoseCommand}"
                                            ToolTip.Tip="Capture the calibration board at the current robot pose"/>
                                    <Button Grid.Column="2" Content="Clear All"
                                            Classes="ToolbarButton"
                                            Command="{Binding Scan.Calibration.ClearPosesCommand}"
                                            ToolTip.Tip="Remove all collected poses and reset"/>
                                </Grid>

                                <TextBlock Text="{Binding Scan.Calibration.CaptureStatus}"
                                           Classes="LabelMuted" Margin="8,0,8,4" TextWrapping="Wrap"/>

                                <Border Height="1" Background="{DynamicResource Border1}" Margin="8,4"/>

                                <!-- Run Calibration -->
                                <Button Content="Run Calibration"
                                        Classes="PrimaryButton" HorizontalAlignment="Stretch"
                                        Margin="8,4,8,2"
                                        Command="{Binding Scan.Calibration.CalibrateCommand}"
                                        ToolTip.Tip="Compute hand-eye calibration from collected poses (requires ≥ 3)"/>
                                <TextBlock Text="{Binding Scan.Calibration.CalibrateStatus}"
                                           Classes="LabelMuted" Margin="8,2,8,4" TextWrapping="Wrap"/>

                                <!-- Result section (shown once a valid result exists) -->
                                <StackPanel IsVisible="{Binding Scan.Calibration.HasResult}">
                                    <Border Height="1" Background="{DynamicResource Border1}" Margin="8,4"/>
                                    <TextBlock Text="RESULT" Classes="SectionHeader"/>

                                    <!-- Residuals -->
                                    <Grid Margin="8,2,8,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Rot residual" Classes="LabelMuted" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Classes="LabelMuted" VerticalAlignment="Center"
                                                   Text="{Binding Scan.Calibration.ResidualRot, StringFormat={}{0:F3} °}"/>
                                    </Grid>
                                    <Grid Margin="8,2,8,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Trans residual" Classes="LabelMuted" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Classes="LabelMuted" VerticalAlignment="Center"
                                                   Text="{Binding Scan.Calibration.ResidualTrans, StringFormat={}{0:F3} mm}"/>
                                    </Grid>

                                    <!-- TCP XYZ -->
                                    <TextBlock Text="CAMERA TCP OFFSET" Classes="SectionHeader"/>
                                    <Grid Margin="8,2,8,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="X" Classes="LabelMuted" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Classes="LabelMuted" VerticalAlignment="Center"
                                                   Text="{Binding Scan.Calibration.ResultX, StringFormat={}{0:F2} mm}"/>
                                    </Grid>
                                    <Grid Margin="8,2,8,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Y" Classes="LabelMuted" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Classes="LabelMuted" VerticalAlignment="Center"
                                                   Text="{Binding Scan.Calibration.ResultY, StringFormat={}{0:F2} mm}"/>
                                    </Grid>
                                    <Grid Margin="8,2,8,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Z" Classes="LabelMuted" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Classes="LabelMuted" VerticalAlignment="Center"
                                                   Text="{Binding Scan.Calibration.ResultZ, StringFormat={}{0:F2} mm}"/>
                                    </Grid>

                                    <!-- TCP ABC -->
                                    <Grid Margin="8,2,8,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="A" Classes="LabelMuted" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Classes="LabelMuted" VerticalAlignment="Center"
                                                   Text="{Binding Scan.Calibration.ResultA, StringFormat={}{0:F3} °}"/>
                                    </Grid>
                                    <Grid Margin="8,2,8,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="B" Classes="LabelMuted" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Classes="LabelMuted" VerticalAlignment="Center"
                                                   Text="{Binding Scan.Calibration.ResultB, StringFormat={}{0:F3} °}"/>
                                    </Grid>
                                    <Grid Margin="8,2,8,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="C" Classes="LabelMuted" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Classes="LabelMuted" VerticalAlignment="Center"
                                                   Text="{Binding Scan.Calibration.ResultC, StringFormat={}{0:F3} °}"/>
                                    </Grid>

                                    <!-- Apply to TCP -->
                                    <Button Content="Apply to TCP"
                                            Classes="PrimaryButton" HorizontalAlignment="Stretch"
                                            Margin="8,4,8,8"
                                            Command="{Binding Scan.Calibration.ApplyToTcpCommand}"
                                            ToolTip.Tip="Write this result into the TCP OFFSET fields for the active tool"/>
                                </StackPanel>

                            </StackPanel>
                        </Expander>

                    </StackPanel>
                </ScrollViewer>

            </Grid>

            <!-- SUBTRACTIVE tab -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{DynamicResource Bg2}"
                          IsVisible="{Binding IsSubtractiveTab}">
                <StackPanel Margin="0,8">
                    <TextBlock Text="MILLING" Classes="SectionHeader"/>
                    <TextBlock Text="HSD ES951 spindle finish — carve a relief into the printed blank."
                               Classes="LabelMuted" Margin="12,0,12,8" TextWrapping="Wrap"/>

                    <!-- Relief heightmap -->
                    <TextBlock Text="RELIEF HEIGHTMAP" Classes="LabelMuted" FontWeight="SemiBold" Margin="8,6,8,4"/>
                    <Grid Margin="8,0,8,4" ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0" Watermark="grayscale .png / .jpg" FontSize="11"
                                 Text="{Binding Subtractive.HeightmapPath, Mode=TwoWay}"/>
                        <Button Grid.Column="1" Content="Browse" Margin="4,0,0,0" FontSize="11"
                                Command="{Binding Subtractive.BrowseHeightmapCommand}"
                                ToolTip.Tip="Pick a grayscale relief image (white = high surface)"/>
                    </Grid>
                    <Grid Margin="8,0,8,4" ColumnDefinitions="*,80">
                        <TextBlock Grid.Column="0" Text="Height scale (mm)" VerticalAlignment="Center" Classes="LabelMuted"/>
                        <NumericUpDown Grid.Column="1" Value="{Binding Subtractive.HeightScaleMm, Mode=TwoWay}"
                                       Minimum="0" Maximum="200" Increment="0.5" FormatString="F1" FontSize="11"/>
                    </Grid>
                    <CheckBox Margin="8,0,8,4" Content="Invert (black = high)" FontSize="11"
                              IsChecked="{Binding Subtractive.InvertHeightmap, Mode=TwoWay}"/>

                    <!-- Tool &amp; cutting -->
                    <TextBlock Text="TOOL &amp; CUTTING" Classes="LabelMuted" FontWeight="SemiBold" Margin="8,6,8,4"/>
                    <Grid Margin="8,0,8,4" ColumnDefinitions="*,80">
                        <TextBlock Grid.Column="0" Text="Tool diameter (mm)" VerticalAlignment="Center" Classes="LabelMuted"/>
                        <NumericUpDown Grid.Column="1" Value="{Binding Subtractive.ToolDiameterMm, Mode=TwoWay}"
                                       Minimum="0.5" Maximum="50" Increment="0.5" FormatString="F1" FontSize="11"/>
                    </Grid>
                    <CheckBox Margin="8,0,8,4" Content="Ball-nose (off = flat end-mill)" FontSize="11"
                              IsChecked="{Binding Subtractive.BallEnd, Mode=TwoWay}"/>
                    <Grid Margin="8,0,8,4" ColumnDefinitions="*,80">
                        <TextBlock Grid.Column="0" Text="Stepover (mm)" VerticalAlignment="Center" Classes="LabelMuted"/>
                        <NumericUpDown Grid.Column="1" Value="{Binding Subtractive.StepoverMm, Mode=TwoWay}"
                                       Minimum="0.1" Maximum="20" Increment="0.1" FormatString="F1" FontSize="11"/>
                    </Grid>
                    <Grid Margin="8,0,8,4" ColumnDefinitions="*,80">
                        <TextBlock Grid.Column="0" Text="Stepdown (mm)" VerticalAlignment="Center" Classes="LabelMuted"/>
                        <NumericUpDown Grid.Column="1" Value="{Binding Subtractive.StepdownMm, Mode=TwoWay}"
                                       Minimum="0.1" Maximum="20" Increment="0.1" FormatString="F1" FontSize="11"/>
                    </Grid>
                    <Grid Margin="8,0,8,4" ColumnDefinitions="*,80">
                        <TextBlock Grid.Column="0" Text="Finish allowance (mm)" VerticalAlignment="Center" Classes="LabelMuted"/>
                        <NumericUpDown Grid.Column="1" Value="{Binding Subtractive.FinishAllowanceMm, Mode=TwoWay}"
                                       Minimum="0" Maximum="10" Increment="0.1" FormatString="F2" FontSize="11"/>
                    </Grid>
                    <Grid Margin="8,0,8,4" ColumnDefinitions="*,80">
                        <TextBlock Grid.Column="0" Text="Feed rate (mm/min)" VerticalAlignment="Center" Classes="LabelMuted"/>
                        <NumericUpDown Grid.Column="1" Value="{Binding Subtractive.FeedRateMmMin, Mode=TwoWay}"
                                       Minimum="100" Maximum="15000" Increment="100" FormatString="F0" FontSize="11"/>
                    </Grid>
                    <Grid Margin="8,0,8,4" ColumnDefinitions="*,80">
                        <TextBlock Grid.Column="0" Text="Plunge feed (mm/min)" VerticalAlignment="Center" Classes="LabelMuted"/>
                        <NumericUpDown Grid.Column="1" Value="{Binding Subtractive.PlungeFeedMmMin, Mode=TwoWay}"
                                       Minimum="50" Maximum="10000" Increment="50" FormatString="F0" FontSize="11"/>
                    </Grid>
                    <Grid Margin="8,0,8,4" ColumnDefinitions="*,80">
                        <TextBlock Grid.Column="0" Text="Safe / rapid Z (mm)" VerticalAlignment="Center" Classes="LabelMuted"/>
                        <NumericUpDown Grid.Column="1" Value="{Binding Subtractive.RapidZMm, Mode=TwoWay}"
                                       Minimum="1" Maximum="500" Increment="1" FormatString="F0" FontSize="11"/>
                    </Grid>
                    <Grid Margin="8,0,8,4" ColumnDefinitions="*,80">
                        <TextBlock Grid.Column="0" Text="Spindle RPM" VerticalAlignment="Center" Classes="LabelMuted"/>
                        <NumericUpDown Grid.Column="1" Value="{Binding Subtractive.SpindleRpm, Mode=TwoWay}"
                                       Minimum="0" Maximum="30000" Increment="500" FormatString="F0" FontSize="11"/>
                    </Grid>

                    <!-- Placement -->
                    <TextBlock Text="PLACEMENT" Classes="LabelMuted" FontWeight="SemiBold" Margin="8,6,8,4"/>
                    <CheckBox Margin="8,0,8,4" Content="Reference Z from part top" FontSize="11"
                              IsChecked="{Binding Subtractive.AutoReferenceFromTop, Mode=TwoWay}"/>
                    <Grid Margin="8,0,8,4" ColumnDefinitions="*,80" IsEnabled="{Binding !Subtractive.AutoReferenceFromTop}">
                        <TextBlock Grid.Column="0" Text="Reference Z (mm)" VerticalAlignment="Center" Classes="LabelMuted"/>
                        <NumericUpDown Grid.Column="1" Value="{Binding Subtractive.ReferencePlaneZ, Mode=TwoWay}"
                                       Increment="1" FormatString="F1" FontSize="11"/>
                    </Grid>
                    <CheckBox Margin="8,0,8,8" Content="Footprint from part bounds" FontSize="11"
                              IsChecked="{Binding Subtractive.AutoFootprint, Mode=TwoWay}"/>

                    <Button Margin="8,4,8,8"
                            Content="Generate Mill Toolpath"
                            Classes="PrimaryButton"
                            HorizontalAlignment="Stretch"
                            ToolTip.Tip="Carve the relief into the selected blank (relief milling)"
                            Command="{Binding $parent[Window].DataContext.Viewport.MillCommand}"/>

                    <Button Margin="8,0,8,4"
                            Content="Export Mill KRL"
                            Classes="PrimaryButton"
                            HorizontalAlignment="Stretch"
                            ToolTip.Tip="Export spindle finish program (uses global home and orientation above)"
                            Command="{Binding $parent[Window].DataContext.Viewport.ExportKrlCommand}"/>

                    <Button Margin="8,0,8,4"
                            Content="Send to Robot"
                            Classes="SecondaryButton"
                            HorizontalAlignment="Stretch"
                            ToolTip.Tip="Save mill KRL to the cell robot"
                            Command="{Binding $parent[Window].DataContext.Viewport.SendToRobotCommand}"/>
                </StackPanel>
            </ScrollViewer>

            <!-- TOOLPATH tab -->
            <Grid Grid.Row="1" IsVisible="{Binding IsToolpathTab}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
            <ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{DynamicResource Bg2}">
                <StackPanel Margin="0,8">
                    <TextBlock Text="TOOLPATH" Classes="SectionHeader"/>

                    <!-- No toolpath selected -->
                    <TextBlock Text="Select a toolpath to view options."
                               Classes="LabelMuted" Margin="12,4"
                               IsVisible="{Binding !$parent[Window].DataContext.Viewport.IsToolpathSelected}"/>

                    <!-- Options — shown only when a toolpath is selected -->
                    <StackPanel IsVisible="{Binding $parent[Window].DataContext.Viewport.IsToolpathSelected}">

                    <Expander Classes="SectionExpander" Header="GLOBAL" IsExpanded="False" Margin="0,0,0,4">
                        <StackPanel>

                        <TextBlock Text="HOME POSITION" Classes="SectionHeader"/>

                        <Grid Margin="8,0,8,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      HorizontalAlignment="Stretch"
                                      Margin="0,0,4,0"
                                      ItemsSource="{Binding Additive.AvailableHomePositionNames}"
                                      SelectedItem="{Binding Additive.SelectedHomePositionName, Mode=TwoWay}"/>
                            <Button Grid.Column="1"
                                    Content="Set Default"
                                    Classes="ToolbarButton"
                                    Command="{Binding Additive.SetDefaultHomePositionCommand}"
                                    ToolTip.Tip="Save this position as the default for the active cell"/>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource Border1}" Margin="8,4"/>

                        <TextBlock Text="TOOLHEAD GLOBAL ORIENTATION" Classes="SectionHeader"
                                   ToolTip.Tip="Global-axis rotations: R_global = Rz(Z) × Ry(Y) × Rx(X). Default 0,90,0 = nozzle vertical."/>

                        <!-- Y (global Y-axis rotation — Ry(90°) makes nozzle point down) -->
                        <Grid Margin="8,0,8,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="56"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Y (°)" Classes="LabelMuted" VerticalAlignment="Center"
                                       ToolTip.Tip="Rotation around the global Y-axis. 90° tilts the nozzle to point straight down."/>
                            <Slider    Grid.Column="1" Minimum="-180" Maximum="180"
                                       Value="{Binding Additive.ToolheadB, Mode=TwoWay}"
                                       VerticalAlignment="Center"/>
                            <TextBox   Grid.Column="2" Classes="PanelTextBox"
                                       Text="{Binding Additive.ToolheadB, Mode=TwoWay, StringFormat={}{0:F1}}"
                                       TextAlignment="Right" Padding="4,2" VerticalContentAlignment="Center"/>
                        </Grid>

                        <!-- X (global X-axis rotation — tilts nozzle side-to-side) -->
                        <Grid Margin="8,4,8,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="56"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="X (°)" Classes="LabelMuted" VerticalAlignment="Center"
                                       ToolTip.Tip="Rotation around the global X-axis. Tilts the nozzle side-to-side."/>
                            <Slider    Grid.Column="1" Minimum="-180" Maximum="180"
                                       Value="{Binding Additive.ToolheadC, Mode=TwoWay}"
                                       VerticalAlignment="Center"/>
                            <TextBox   Grid.Column="2" Classes="PanelTextBox"
                                       Text="{Binding Additive.ToolheadC, Mode=TwoWay, StringFormat={}{0:F1}}"
                                       TextAlignment="Right" Padding="4,2" VerticalContentAlignment="Center"/>
                        </Grid>

                        <!-- Z (global Z-axis rotation — spins tool around vertical axis) -->
                        <Grid Margin="8,4,8,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="56"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Z (°)" Classes="LabelMuted" VerticalAlignment="Center"
                                       ToolTip.Tip="Rotation around the global Z-axis. Spins the tool frame around the vertical axis (heading/yaw)."/>
                            <Slider    Grid.Column="1" Minimum="-180" Maximum="180"
                                       Value="{Binding Additive.ToolheadA, Mode=TwoWay}"
                                       VerticalAlignment="Center"/>
                            <TextBox   Grid.Column="2" Classes="PanelTextBox"
                                       Text="{Binding Additive.ToolheadA, Mode=TwoWay, StringFormat={}{0:F1}}"
                                       TextAlignment="Right" Padding="4,2" VerticalContentAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource Border1}" Margin="8,4"/>

                        <StackPanel IsVisible="{Binding $parent[Window].DataContext.Viewport.IsMergedToolpathSelected}">
                            <TextBlock Text="MERGED TOOLPATH" Classes="SectionHeader"
                                       ToolTip.Tip="Connector settings between the original toolpath segments"/>

                            <Grid Margin="8,0,8,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Retraction height (mm)"
                                           VerticalAlignment="Center" Classes="LabelMuted"
                                           ToolTip.Tip="Z-hop lift after each segment finishes before traveling to the next"/>
                                <NumericUpDown Grid.Column="1"
                                               Value="{Binding $parent[Window].DataContext.Viewport.MergedRetractionHeightMm, Mode=TwoWay}"
                                               Minimum="0" Maximum="200" Increment="1"
                                               FormatString="F1" FontSize="11"/>
                            </Grid>

                            <Grid Margin="8,0,8,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Travel speed (mm/s)"
                                           VerticalAlignment="Center" Classes="LabelMuted"
                                           ToolTip.Tip="Speed for connector moves between merged segments"/>
                                <NumericUpDown Grid.Column="1"
                                               Value="{Binding $parent[Window].DataContext.Viewport.MergedTravelSpeed, Mode=TwoWay}"
                                               Minimum="1" Maximum="2000" Increment="10"
                                               FormatString="F0" FontSize="11"/>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource Border1}" Margin="8,4"/>
                        </StackPanel>

                        <TextBlock Text="VISIBILITY" Classes="SectionHeader"/>

                        <CheckBox Content="Show bead"            Margin="12,2,8,2"
                                  IsChecked="{Binding $parent[Window].DataContext.Viewport.ShowBead, Mode=TwoWay}"/>
                        <CheckBox Content="Show extrusion moves" Margin="12,2,8,2"
                                  IsChecked="{Binding $parent[Window].DataContext.Viewport.ShowExtrusionMoves, Mode=TwoWay}"/>
                        <CheckBox Content="Show travel moves"    Margin="12,2,8,2"
                                  IsChecked="{Binding $parent[Window].DataContext.Viewport.ShowTravelMoves, Mode=TwoWay}"/>
                        <CheckBox Content="Show seam"            Margin="12,2,8,6"
                                  IsChecked="{Binding $parent[Window].DataContext.Viewport.ShowSeam, Mode=TwoWay}"/>

                        <Border Height="1" Background="{DynamicResource Border1}" Margin="8,4"/>

                        <TextBlock Text="SIMULATION" Classes="SectionHeader"/>

                        <Grid Margin="8,0,8,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="$APO.CVEL (%)" VerticalAlignment="Center" Classes="LabelMuted"
                                       ToolTip.Tip="Minimum speed fraction at corners (KUKA $APO.CVEL). 50 = slow to 50% on sharp turns. Set this to match your KRL preset to get accurate timing."/>
                            <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Additive.ApoCvel}"/>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource Border1}" Margin="8,4"/>

                        <TextBlock Text="ORIENTATION SMOOTHING" Classes="SectionHeader"
                                   ToolTip.Tip="Averages toolhead ABC angles across neighbouring moves to prevent sharp reorientation jumps that can over-accelerate the robot. Positions are unchanged."/>

                        <CheckBox Content="Smooth rotation"
                                  IsChecked="{Binding Additive.SmoothRotation, Mode=TwoWay}"
                                  Margin="12,2,8,2"/>
                        <Grid Margin="8,2,8,2" IsVisible="{Binding Additive.ShowSmoothRotationRadius}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Radius (moves)"
                                       VerticalAlignment="Center" Classes="LabelMuted"
                                       ToolTip.Tip="Number of moves averaged on each side. Higher = smoother but deviates further from mesh normals."/>
                            <NumericUpDown Grid.Column="1"
                                           Value="{Binding Additive.SmoothRotationRadius, Mode=TwoWay}"
                                           Minimum="1" Maximum="50" Increment="1"
                                           FormatString="F0" FontSize="11"/>
                        </Grid>

                        <Grid Margin="8,2,8,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Max rate (°/mm)"
                                       VerticalAlignment="Center" Classes="LabelMuted"
                                       ToolTip.Tip="Maximum orientation change in degrees per mm of travel. Clamps sharp turns to prevent KUKA axis overspeed. 0 = disabled."/>
                            <NumericUpDown Grid.Column="1"
                                           Value="{Binding Additive.SmoothRotationMaxRateDegPerMm, Mode=TwoWay}"
                                           Minimum="0" Maximum="90" Increment="0.5"
                                           FormatString="F1" FontSize="11"/>
                        </Grid>

                        <Grid Margin="8,2,8,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="KRL look-ahead (mm)"
                                       VerticalAlignment="Center" Classes="LabelMuted"
                                       ToolTip.Tip="Forward look-ahead distance for the KRL exporter's Gaussian normal smoother. At 60 mm/s this is approx. 1 second of pre-rotation per 60 mm. 0 = disabled."/>
                            <NumericUpDown Grid.Column="1"
                                           Value="{Binding Additive.OrientationLookAheadMm, Mode=TwoWay}"
                                           Minimum="0" Maximum="500" Increment="10"
                                           FormatString="F0" FontSize="11"/>
                        </Grid>

                        <Grid Margin="8,2,8,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="KRL sigma (mm)"
                                       VerticalAlignment="Center" Classes="LabelMuted"
                                       ToolTip.Tip="Gaussian kernel width for KRL normal smoothing. Controls the spread of the orientation transition ramp. Typically half of the look-ahead value."/>
                            <NumericUpDown Grid.Column="1"
                                           Value="{Binding Additive.OrientationSigmaMm, Mode=TwoWay}"
                                           Minimum="1" Maximum="200" Increment="5"
                                           FormatString="F0" FontSize="11"/>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource Border1}" Margin="8,4"/>

                        </StackPanel>
                    </Expander>

                    <Expander Classes="SectionExpander"
                              Header="PRINT TOOLPATH"
                              IsExpanded="False"
                              Margin="0,0,0,4"
                              IsVisible="{Binding $parent[Window].DataContext.Viewport.Lfam3ToolpathShowPrintOptions}">
                        <StackPanel>

                        <TextBlock Text="Pellet extrusion paths — export temps and RPM to KUKA $ANOUT."
                                   Classes="LabelMuted" Margin="8,0,8,6" TextWrapping="Wrap"/>

                        <Button Content="Update Slice"
                                Classes="SecondaryButton"
                                HorizontalAlignment="Stretch"
                                Margin="8,4,8,4"
                                ToolTip.Tip="Re-slice the source mesh at its current position/rotation/scale using current settings, and replace this toolpath."
                                Command="{Binding $parent[Window].DataContext.Viewport.UpdateSliceCommand}"/>

                        <TextBlock Text="KRL EXPORT" Classes="SectionHeader"
                                   ToolTip.Tip="Values written to the SRC file. Temperatures and extrusion speed are converted to $ANOUT automatically."/>

                        <Grid Margin="8,0,8,4" ColumnDefinitions="*,44,44">
                            <TextBlock Grid.Column="0" Text="Temp all zones (°C)"
                                       VerticalAlignment="Center" Classes="LabelMuted"
                                       ToolTip.Tip="Material preset temperature for all extruder zones. Written to $ANOUT[1–3] at export."/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Additive.ExportTemperatureC, StringFormat={}{0:F0}}"
                                       VerticalAlignment="Center" TextAlignment="Right" Classes="LabelMuted"/>
                            <TextBox   Grid.Column="2" Classes="PanelTextBox" Margin="4,0,0,0"
                                       Text="{Binding Additive.TemperatureOffset, Mode=TwoWay}"
                                       PlaceholderText="+/-"
                                       ToolTip.Tip="Optional ±°C adjustment applied to all zones. +10 raises export temp by 10°C; -10 lowers it. Leave empty for no change."/>
                        </Grid>

                        <Grid Margin="8,0,8,4" ColumnDefinitions="*,44,44">
                            <TextBlock Grid.Column="0" Text="Extrusion Speed"
                                       VerticalAlignment="Center" Classes="LabelMuted"
                                       ToolTip.Tip="Computed from bead width, layer height, print speed, and material flow. Written to $ANOUT[4] at export."/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Additive.ExtrusionSpeedPercent, StringFormat={}{0:F0}%}"
                                       VerticalAlignment="Center" TextAlignment="Right" Classes="LabelMuted"/>
                            <TextBox   Grid.Column="2" Classes="PanelTextBox" Margin="4,0,0,0"
                                       Text="{Binding Additive.ExtrusionSpeedOffset, Mode=TwoWay}"
                                       PlaceholderText="+/-"
                                       ToolTip.Tip="Optional ±% adjustment. +10 exports 10 points higher; -10 exports 10 points lower. Leave empty for no change."/>
                        </Grid>

                        <Grid Margin="8,0,8,4" ColumnDefinitions="*,Auto">
                            <Button Grid.Column="0"
                                    Content="Export KRL"
                                    Classes="PrimaryButton"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding $parent[Window].DataContext.Viewport.ExportKrlCommand}"/>
                            <Button Grid.Column="1"
                                    Classes="ToolbarButton"
                                    Margin="6,0,0,0"
                                    Padding="8,6"
                                    Click="OnKrlPostProcessClicked"
                                    ToolTip.Tip="KRL post-processing: travel rules, SRC header, and footer">
                                <ia:Icon Value="mdi-cog" FontSize="16"/>
                            </Button>
                        </Grid>

                        <Button Margin="8,0,8,4"
                                Content="Send to Robot"
                                Classes="SecondaryButton"
                                HorizontalAlignment="Stretch"
                                ToolTip.Tip="Save KRL to this cell's robot D: drive (\\?\UNC\bridgeIp\d). Filename defaults to yyyy_MMdd - name.src."
                                Command="{Binding $parent[Window].DataContext.Viewport.SendToRobotCommand}"/>

                        </StackPanel>
                    </Expander>

                    <!-- Scan-phase toolpath options -->
                    <Expander Classes="SectionExpander"
                              Header="SCAN TOOLPATH"
                              IsExpanded="False"
                              Margin="0,0,0,4"
                              IsVisible="{Binding $parent[Window].DataContext.Viewport.Lfam3ToolpathShowScanOptions}">
                        <StackPanel>

                        <TextBlock Text="Scanner bed capture and verification moves."
                                   Classes="LabelMuted" Margin="8,0,8,6" TextWrapping="Wrap"/>

                        <Grid Margin="8,0,8,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="56"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="TOOL data index" VerticalAlignment="Center" Classes="LabelMuted"/>
                            <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Scan.ToolDataIndex, Mode=TwoWay}"/>
                        </Grid>

                        <Grid Margin="8,0,8,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="56"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="BASE data index" VerticalAlignment="Center" Classes="LabelMuted"/>
                            <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Scan.BaseDataIndex, Mode=TwoWay}"/>
                        </Grid>

                        <Grid Margin="8,0,8,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Camera IP" VerticalAlignment="Center" Classes="LabelMuted"/>
                            <TextBox   Grid.Column="1" Classes="PanelTextBox" Text="{Binding Scan.CameraIp, Mode=TwoWay}"/>
                        </Grid>

                        <Button Margin="8,4,8,4"
                                Content="Test Scan Capture"
                                Classes="SecondaryButton"
                                HorizontalAlignment="Stretch"
                                Command="{Binding Scan.TestScanCommand}"
                                ToolTip.Tip="Run a single Zivid capture using the scan toolpath pose"/>

                        <TextBlock Text="{Binding Scan.ScanStatus}"
                                   Classes="LabelMuted"
                                   FontSize="10"
                                   Margin="8,0,8,4"
                                   TextWrapping="Wrap"/>

                        <Button Margin="8,0,8,4"
                                Content="Export Scan KRL"
                                Classes="PrimaryButton"
                                HorizontalAlignment="Stretch"
                                ToolTip.Tip="Export scanner motion program (uses global home and orientation above)"
                                Command="{Binding $parent[Window].DataContext.Viewport.ExportKrlCommand}"/>

                        </StackPanel>
                    </Expander>

                    <!-- Mill-phase relief milling lives in the SUBTRACTIVE tab (auto-selected on the Mill phase). -->

                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
            </Grid>

        </Grid>
    </Border>

</UserControl>
