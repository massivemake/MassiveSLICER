<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MassiveSlicer.App.Views"
             x:Class="MassiveSlicer.App.Views.ViewportView"
             Background="#07090f">

    <!-- GlHostControl renders off-screen via PBO and presents into a WriteableBitmap.
         No native HWND is visible, so ViewportOverlayView stacks on top with no
         Win32 airspace problem — it is just a regular Avalonia grid child. -->
    <Grid>
        <local:GlHostControl x:Name="GlCanvas"/>
        <local:ViewportOverlayView x:Name="OverlayView"/>
    </Grid>

</UserControl>
