<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MassiveSlicer.ViewModels"
        xmlns:ia="https://github.com/projektanker/icons.avalonia"
        x:Class="MassiveSlicer.App.Views.MaterialPresetDialog"
        x:CompileBindings="False"
        Title="Material Preset"
        Width="400" Height="460"
        WindowStartupLocation="CenterOwner"
        WindowDecorations="None"
        CanResize="False"
        ShowInTaskbar="False"
        Background="{DynamicResource Bg0}">

    <Border BorderBrush="{DynamicResource Border2}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="44"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" x:Name="TitleBar"
                    Background="{DynamicResource Bg1}"
                    BorderBrush="{DynamicResource Border1}"
                    BorderThickness="0,0,0,1"
                    Cursor="SizeAll">
                <Grid Margin="14,0">
                    <TextBlock Text="Material Preset"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Classes="ToolbarButton"
                            Padding="6,2"
                            Click="OnCancel">
                        <ia:Icon Value="mdi-close" FontSize="14"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Form body -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Background="{DynamicResource Bg2}">
                <StackPanel Margin="20,16,20,16">

                    <!-- Identification -->
                    <TextBlock Text="IDENTIFICATION" Classes="SectionHeader" Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Name" Classes="LabelMuted" VerticalAlignment="Center"/>
                        <TextBox   Grid.Column="1" Classes="PanelTextBox"
                                   Text="{Binding Name, Mode=TwoWay}"/>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Material type" Classes="LabelMuted" VerticalAlignment="Center"/>
                        <ComboBox  Grid.Column="1" HorizontalAlignment="Stretch"
                                   ItemsSource="{x:Static vm:MaterialPresetEditorViewModel.MaterialTypes}"
                                   SelectedItem="{Binding MaterialType, Mode=TwoWay}"/>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Color" Classes="LabelMuted" VerticalAlignment="Center"/>
                        <ComboBox  Grid.Column="1" HorizontalAlignment="Stretch"
                                   ItemsSource="{x:Static vm:MaterialPresetEditorViewModel.Colors}"
                                   SelectedItem="{Binding Color, Mode=TwoWay}"/>
                    </Grid>

                    <Border Height="1" Background="{DynamicResource Border1}" Margin="0,10,0,10"/>

                    <!-- Temperatures -->
                    <TextBlock Text="TEMPERATURES (°C)" Classes="SectionHeader" Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="T1" Classes="LabelMuted" VerticalAlignment="Center"/>
                        <TextBox   Grid.Column="1" Classes="PanelTextBox"
                                   Text="{Binding Temperature1, Mode=TwoWay, StringFormat={}{0:F1}}"/>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="T2" Classes="LabelMuted" VerticalAlignment="Center"/>
                        <TextBox   Grid.Column="1" Classes="PanelTextBox"
                                   Text="{Binding Temperature2, Mode=TwoWay, StringFormat={}{0:F1}}"/>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="T3" Classes="LabelMuted" VerticalAlignment="Center"/>
                        <TextBox   Grid.Column="1" Classes="PanelTextBox"
                                   Text="{Binding Temperature3, Mode=TwoWay, StringFormat={}{0:F1}}"/>
                    </Grid>

                    <Border Height="1" Background="{DynamicResource Border1}" Margin="0,10,0,10"/>

                    <!-- Extrusion properties -->
                    <TextBlock Text="PROPERTIES" Classes="SectionHeader" Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Flow rate (rev/cm³)" Classes="LabelMuted" VerticalAlignment="Center"/>
                        <TextBox   Grid.Column="1" Classes="PanelTextBox"
                                   Text="{Binding FlowRate, Mode=TwoWay, StringFormat={}{0:F4}}"/>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Density (g/cm³)" Classes="LabelMuted" VerticalAlignment="Center"/>
                        <TextBox   Grid.Column="1" Classes="PanelTextBox"
                                   Text="{Binding MaterialDensity, Mode=TwoWay, StringFormat={}{0:F3}}"/>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Cost ($/lb)" Classes="LabelMuted" VerticalAlignment="Center"/>
                        <TextBox   Grid.Column="1" Classes="PanelTextBox"
                                   Text="{Binding CostPerLb, Mode=TwoWay, StringFormat={}{0:F2}}"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{DynamicResource Bg1}"
                    BorderBrush="{DynamicResource Border1}"
                    BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Spacing="8"
                            Margin="0,0,16,0">
                    <Button Content="Cancel"
                            Classes="ToolbarButton"
                            Padding="14,6"
                            Click="OnCancel"/>
                    <Button Content="Save"
                            Classes="PrimaryButton"
                            Padding="14,6"
                            Click="OnSave"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>

</Window>
