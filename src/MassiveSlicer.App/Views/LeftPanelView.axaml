<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:MassiveSlicer.Converters;assembly=MassiveSlicer.App"
             x:Class="MassiveSlicer.App.Views.LeftPanelView"
             x:CompileBindings="False">

    <UserControl.Resources>
        <converters:EnumMatchConverter x:Key="EnumMatchCvt"/>
    </UserControl.Resources>

    <Border Background="{DynamicResource Bg2}"
            BorderBrush="{DynamicResource Border1}"
            BorderThickness="0,0,1,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Panel header -->
            <Border Grid.Row="0"
                    Background="{DynamicResource Bg3}"
                    BorderBrush="{DynamicResource Border1}"
                    BorderThickness="0,0,0,1">
                <TextBlock Text="WORKSPACE"
                           Classes="SectionHeader"
                           Margin="8,0"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Robot cell selector -->
            <Border Grid.Row="1"
                    Background="{DynamicResource Bg2}"
                    Padding="8,6"
                    BorderBrush="{DynamicResource Border1}"
                    BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="ROBOT CELL" Classes="LabelMuted" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding CellNames}"
                              SelectedIndex="{Binding SelectedCellIndex, Mode=TwoWay}"
                              HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Border>

            <!-- Separator -->
            <Border Grid.Row="2" Background="{DynamicResource Border1}"/>

            <!-- Tab bar -->
            <Border Grid.Row="3"
                    Background="{DynamicResource Bg3}"
                    BorderBrush="{DynamicResource Border1}"
                    BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal">
                    <Button Content="OUTLINER" Classes="TabButton"
                            Command="{Binding SetTabCommand}" CommandParameter="Outliner"/>
                    <Button Content="ASSETS"   Classes="TabButton"
                            Command="{Binding SetTabCommand}" CommandParameter="Assets"/>
                    <Button Content="VIEWPORT" Classes="TabButton"
                            Command="{Binding SetTabCommand}" CommandParameter="Viewport"/>
                </StackPanel>
            </Border>

            <!-- Tab content -->
            <Grid Grid.Row="4">

                <!-- Outliner tab -->
                <ListBox ItemsSource="{Binding OutlinerItems}"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         IsVisible="{Binding IsOutlinerTabActive}">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover">
                            <Setter Property="Background" Value="{DynamicResource Bg4}"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected">
                            <Setter Property="Background" Value="{DynamicResource AccentMuted}"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected:pointerover">
                            <Setter Property="Background" Value="{DynamicResource AccentMuted}"/>
                        </Style>
                    </ListBox.Styles>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="6,0,4,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Name}"
                                           VerticalAlignment="Center"
                                           Padding="0,5"/>
                                <Button Grid.Column="1"
                                        Content="×"
                                        Command="{Binding DeleteCommand}"
                                        Classes="ToolbarButton"
                                        Padding="5,2"
                                        Margin="2,2,0,2"
                                        FontSize="14"
                                        Foreground="{DynamicResource TextSecondary}"
                                        ToolTip.Tip="Remove from scene"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Assets tab placeholder -->
                <Border Background="{DynamicResource Bg2}"
                        IsVisible="{Binding IsAssetsTabActive}">
                    <TextBlock Text="Asset browser not yet implemented."
                               Classes="LabelMuted"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="16"/>
                </Border>

                <!-- Viewport tab -->
                <ScrollViewer IsVisible="{Binding IsViewportTabActive}"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,6">

                        <!-- Backdrop -->
                        <TextBlock Text="BACKDROP" Classes="SectionHeader" Margin="0,0,0,6"/>
                        <ComboBox HorizontalAlignment="Stretch"
                                  Margin="0,0,0,4"
                                  ItemsSource="{Binding DataContext.Viewport.AvailableBackdrops,
                                                RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                  SelectedItem="{Binding DataContext.Viewport.ActiveBackdrop,
                                                 RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                 Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Content="Set as Default"
                                Classes="ToolbarButton"
                                HorizontalAlignment="Right"
                                Margin="0,0,0,8"
                                Command="{Binding DataContext.Viewport.SetDefaultBackdropCommand,
                                          RelativeSource={RelativeSource AncestorType={x:Type Window}}}"/>

                        <!-- Blur -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Blur"
                                       Classes="LabelMuted"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <Slider Grid.Column="1"
                                    Minimum="0" Maximum="7"
                                    VerticalAlignment="Center"
                                    Value="{Binding DataContext.Viewport.BackdropBlur,
                                            RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                            Mode=TwoWay}"
                                    ToolTip.Tip="Backdrop blur"/>
                        </Grid>

                        <!-- Shader mode — circular sphere buttons matching the prototype matcap grid.
                             Center/GradientOrigin use % for relative coords; Radius is fraction of longest edge. -->
                        <TextBlock Text="SHADER" Classes="SectionHeader" Margin="0,0,0,8"/>
                        <WrapPanel HorizontalAlignment="Center">

                            <Button Classes="ShaderSphereBtn" Margin="3"
                                    ToolTip.Tip="Standard"
                                    Classes.active="{Binding DataContext.Viewport.ActiveShaderMode,
                                                     RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                     Converter={StaticResource EnumMatchCvt}, ConverterParameter=Standard}"
                                    Command="{Binding DataContext.Viewport.SetShaderModeCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="Standard">
                                <Button.Background>
                                    <RadialGradientBrush Center="38%,35%" GradientOrigin="38%,35%" RadiusX="70%" RadiusY="70%">
                                        <GradientStop Color="#d0d0cc" Offset="0"/>
                                        <GradientStop Color="#888888" Offset="0.55"/>
                                        <GradientStop Color="#333333" Offset="1"/>
                                    </RadialGradientBrush>
                                </Button.Background>
                            </Button>

                            <Button Classes="ShaderSphereBtn" Margin="3"
                                    ToolTip.Tip="Clay"
                                    Classes.active="{Binding DataContext.Viewport.ActiveShaderMode,
                                                     RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                     Converter={StaticResource EnumMatchCvt}, ConverterParameter=Clay}"
                                    Command="{Binding DataContext.Viewport.SetShaderModeCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="Clay">
                                <Button.Background>
                                    <RadialGradientBrush Center="38%,35%" GradientOrigin="38%,35%" RadiusX="70%" RadiusY="70%">
                                        <GradientStop Color="#d4956a" Offset="0"/>
                                        <GradientStop Color="#a0522d" Offset="0.55"/>
                                        <GradientStop Color="#3d1a08" Offset="1"/>
                                    </RadialGradientBrush>
                                </Button.Background>
                            </Button>

                            <Button Classes="ShaderSphereBtn" Margin="3"
                                    ToolTip.Tip="Metal"
                                    Classes.active="{Binding DataContext.Viewport.ActiveShaderMode,
                                                     RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                     Converter={StaticResource EnumMatchCvt}, ConverterParameter=Metal}"
                                    Command="{Binding DataContext.Viewport.SetShaderModeCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="Metal">
                                <Button.Background>
                                    <RadialGradientBrush Center="38%,35%" GradientOrigin="38%,35%" RadiusX="70%" RadiusY="70%">
                                        <GradientStop Color="#f0f0f0" Offset="0"/>
                                        <GradientStop Color="#909090" Offset="0.40"/>
                                        <GradientStop Color="#202020" Offset="0.75"/>
                                        <GradientStop Color="#707070" Offset="1"/>
                                    </RadialGradientBrush>
                                </Button.Background>
                            </Button>

                            <Button Classes="ShaderSphereBtn" Margin="3"
                                    ToolTip.Tip="Chrome"
                                    Classes.active="{Binding DataContext.Viewport.ActiveShaderMode,
                                                     RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                     Converter={StaticResource EnumMatchCvt}, ConverterParameter=Chrome}"
                                    Command="{Binding DataContext.Viewport.SetShaderModeCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="Chrome">
                                <Button.Background>
                                    <RadialGradientBrush Center="38%,35%" GradientOrigin="38%,35%" RadiusX="70%" RadiusY="70%">
                                        <GradientStop Color="#ffffff" Offset="0"/>
                                        <GradientStop Color="#ffffff" Offset="0.15"/>
                                        <GradientStop Color="#555555" Offset="0.40"/>
                                        <GradientStop Color="#eeeeee" Offset="0.60"/>
                                        <GradientStop Color="#333333" Offset="0.80"/>
                                        <GradientStop Color="#aaaaaa" Offset="1"/>
                                    </RadialGradientBrush>
                                </Button.Background>
                            </Button>

                            <Button Classes="ShaderSphereBtn" Margin="3"
                                    ToolTip.Tip="Matte Black"
                                    Classes.active="{Binding DataContext.Viewport.ActiveShaderMode,
                                                     RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                     Converter={StaticResource EnumMatchCvt}, ConverterParameter=MatteBlack}"
                                    Command="{Binding DataContext.Viewport.SetShaderModeCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="MatteBlack">
                                <Button.Background>
                                    <RadialGradientBrush Center="38%,35%" GradientOrigin="38%,35%" RadiusX="70%" RadiusY="70%">
                                        <GradientStop Color="#444444" Offset="0"/>
                                        <GradientStop Color="#111111" Offset="0.55"/>
                                        <GradientStop Color="#000000" Offset="1"/>
                                    </RadialGradientBrush>
                                </Button.Background>
                            </Button>

                            <Button Classes="ShaderSphereBtn" Margin="3"
                                    ToolTip.Tip="Purple"
                                    Classes.active="{Binding DataContext.Viewport.ActiveShaderMode,
                                                     RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                     Converter={StaticResource EnumMatchCvt}, ConverterParameter=Purple}"
                                    Command="{Binding DataContext.Viewport.SetShaderModeCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="Purple">
                                <Button.Background>
                                    <RadialGradientBrush Center="38%,35%" GradientOrigin="38%,35%" RadiusX="70%" RadiusY="70%">
                                        <GradientStop Color="#c8a0f0" Offset="0"/>
                                        <GradientStop Color="#7030c0" Offset="0.55"/>
                                        <GradientStop Color="#1a0040" Offset="1"/>
                                    </RadialGradientBrush>
                                </Button.Background>
                            </Button>

                            <Button Classes="ShaderSphereBtn" Margin="3"
                                    ToolTip.Tip="Normals"
                                    Classes.active="{Binding DataContext.Viewport.ActiveShaderMode,
                                                     RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                     Converter={StaticResource EnumMatchCvt}, ConverterParameter=Normals}"
                                    Command="{Binding DataContext.Viewport.SetShaderModeCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="Normals">
                                <Button.Background>
                                    <RadialGradientBrush Center="38%,35%" GradientOrigin="38%,35%" RadiusX="70%" RadiusY="70%">
                                        <GradientStop Color="#ff9090" Offset="0"/>
                                        <GradientStop Color="#8888ff" Offset="0.50"/>
                                        <GradientStop Color="#22cc88" Offset="1"/>
                                    </RadialGradientBrush>
                                </Button.Background>
                            </Button>

                        </WrapPanel>

                        <!-- Lighting -->
                        <Border Height="1" Background="{DynamicResource Border1}" Margin="0,10,0,10"/>
                        <TextBlock Text="LIGHTING" Classes="SectionHeader" Margin="0,0,0,6"/>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Azimuth" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="360" VerticalAlignment="Center"
                                    Value="{Binding DataContext.Viewport.LightAzimuth,
                                            RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"
                                    ToolTip.Tip="Light azimuth (horizontal rotation)"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Elevation" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="90" VerticalAlignment="Center"
                                    Value="{Binding DataContext.Viewport.LightElevation,
                                            RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"
                                    ToolTip.Tip="Light elevation (vertical angle)"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Intensity" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="2" VerticalAlignment="Center"
                                    Value="{Binding DataContext.Viewport.LightIntensity,
                                            RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"
                                    ToolTip.Tip="Light intensity"/>
                        </Grid>

                        <!-- Visibility toggles -->
                        <Border Height="1" Background="{DynamicResource Border1}" Margin="0,10,0,10"/>
                        <TextBlock Text="VISIBILITY" Classes="SectionHeader" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Grid"     Foreground="{DynamicResource TextPrimary}" FontSize="12" VerticalAlignment="Center"/>
                            <CheckBox  Grid.Column="1" VerticalAlignment="Center"
                                       IsChecked="{Binding DataContext.Viewport.ShowGrid,
                                                   RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Axes"     Foreground="{DynamicResource TextPrimary}" FontSize="12" VerticalAlignment="Center"/>
                            <CheckBox  Grid.Column="1" VerticalAlignment="Center"
                                       IsChecked="{Binding DataContext.Viewport.ShowAxes,
                                                   RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Bed grid" Foreground="{DynamicResource TextPrimary}" FontSize="12" VerticalAlignment="Center"/>
                            <CheckBox  Grid.Column="1" VerticalAlignment="Center"
                                       IsChecked="{Binding DataContext.Viewport.ShowBedGrid,
                                                   RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"/>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Grid>
    </Border>

</UserControl>
