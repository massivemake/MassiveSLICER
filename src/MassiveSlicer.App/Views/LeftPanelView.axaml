<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:MassiveSlicer.Converters;assembly=MassiveSlicer.App"
             xmlns:ia="https://github.com/projektanker/icons.avalonia"
             xmlns:views="clr-namespace:MassiveSlicer.App.Views"
             x:Class="MassiveSlicer.App.Views.LeftPanelView"
             x:CompileBindings="False">

    <UserControl.Resources>
        <converters:EnumMatchConverter x:Key="EnumMatchCvt"/>
        <converters:BoolToEyeIconConverter x:Key="BoolToEyeIcon"/>
    </UserControl.Resources>

    <Border Background="{DynamicResource Bg2}"
            BorderBrush="{DynamicResource Border1}"
            BorderThickness="0,0,1,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Panel header -->
            <Border Grid.Row="0"
                    Background="{DynamicResource Bg3}"
                    BorderBrush="{DynamicResource Border1}"
                    BorderThickness="0,0,0,1">
                <TextBlock Text="WORKSPACE"
                           Classes="SectionHeader"
                           Margin="8,0"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Robot cell selector -->
            <Border Grid.Row="1"
                    Background="{DynamicResource Bg2}"
                    Padding="8,6"
                    BorderBrush="{DynamicResource Border1}"
                    BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="ROBOT CELL" Classes="LabelMuted" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding CellNames}"
                              SelectedIndex="{Binding SelectedCellIndex, Mode=TwoWay}"
                              HorizontalAlignment="Stretch"
                              Margin="0,0,0,6"/>
                    <Button Content="{Binding DataContext.RightPanel.Settings.Robot.SyncButtonLabel,
                                             RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                            Classes="ToolbarButton"
                            Classes.active="{Binding DataContext.RightPanel.Settings.Robot.IsConnected,
                                             RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                            HorizontalAlignment="Stretch"
                            BorderBrush="{DynamicResource Border2}"
                            BorderThickness="1"
                            Command="{Binding DataContext.Toolbar.SyncRobotCommand,
                                      RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                            ToolTip.Tip="Connect to the KRC4 controller (live joint streaming). Click again to desync."/>
                </StackPanel>
            </Border>

            <!-- Separator -->
            <Border Grid.Row="2" Background="{DynamicResource Border1}"/>

            <!-- Tab bar -->
            <Border Grid.Row="3"
                    Background="{DynamicResource Bg3}"
                    BorderBrush="{DynamicResource Border1}"
                    BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal">
                    <Button Content="OUTLINER" Classes="TabButton"
                            Classes.active="{Binding IsOutlinerTabActive}"
                            Command="{Binding SetTabCommand}" CommandParameter="Outliner"/>
                    <Button Content="ROBOT"    Classes="TabButton"
                            Classes.active="{Binding IsRobotTabActive}"
                            Command="{Binding SetTabCommand}" CommandParameter="Robot"/>
                    <Button Content="VIEWPORT" Classes="TabButton"
                            Classes.active="{Binding IsViewportTabActive}"
                            Command="{Binding SetTabCommand}" CommandParameter="Viewport"/>
                </StackPanel>
            </Border>

            <!-- Tab content -->
            <Grid Grid.Row="4">

                <!-- Outliner tab (ItemsControl — not ListBox — so nested scan rows don't highlight the bed parent) -->
                <ScrollViewer IsVisible="{Binding IsOutlinerTabActive}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="Transparent">
                    <ItemsControl ItemsSource="{Binding OutlinerItems}" Padding="0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <views:OutlinerItemView Margin="6,0,0,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Viewport tab -->
                <ScrollViewer IsVisible="{Binding IsViewportTabActive}"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,6">

                        <!-- Backdrop -->
                        <TextBlock Text="BACKDROP" Classes="SectionHeader" Margin="0,0,0,6"/>
                        <ComboBox HorizontalAlignment="Stretch"
                                  Margin="0,0,0,4"
                                  ItemsSource="{Binding DataContext.Viewport.AvailableBackdrops,
                                                RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                  SelectedItem="{Binding DataContext.Viewport.ActiveBackdrop,
                                                 RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                 Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <!-- Opacity -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Opacity"
                                       Classes="LabelMuted"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <Slider Grid.Column="1"
                                    Minimum="0" Maximum="1"
                                    VerticalAlignment="Center"
                                    Value="{Binding DataContext.Viewport.BackdropOpacity,
                                            RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                            Mode=TwoWay}"
                                    ToolTip.Tip="Blend HDR backdrop over the shader background (works in all shader modes including Arctic)"/>
                        </Grid>
                        <!-- Blur -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Blur"
                                       Classes="LabelMuted"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <Slider Grid.Column="1"
                                    Minimum="0" Maximum="7"
                                    VerticalAlignment="Center"
                                    Value="{Binding DataContext.Viewport.BackdropBlur,
                                            RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                            Mode=TwoWay}"
                                    ToolTip.Tip="Backdrop blur"/>
                        </Grid>

                        <!-- Shader mode — circular sphere buttons matching the prototype matcap grid.
                             Center/GradientOrigin use % for relative coords; Radius is fraction of longest edge. -->
                        <TextBlock Text="SHADER" Classes="SectionHeader" Margin="0,0,0,8"/>
                        <WrapPanel HorizontalAlignment="Center">

                            <Button Classes="ShaderSphereBtn" Margin="3"
                                    ToolTip.Tip="Standard"
                                    Classes.active="{Binding DataContext.Viewport.ActiveShaderMode,
                                                     RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                     Converter={StaticResource EnumMatchCvt}, ConverterParameter=Standard}"
                                    Command="{Binding DataContext.Viewport.SetShaderModeCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="Standard">
                                <Button.Background>
                                    <RadialGradientBrush Center="38%,35%" GradientOrigin="38%,35%" RadiusX="70%" RadiusY="70%">
                                        <GradientStop Color="#d0d0cc" Offset="0"/>
                                        <GradientStop Color="#888888" Offset="0.55"/>
                                        <GradientStop Color="#333333" Offset="1"/>
                                    </RadialGradientBrush>
                                </Button.Background>
                            </Button>

                            <Button Classes="ShaderSphereBtn" Margin="3"
                                    ToolTip.Tip="Clay"
                                    Classes.active="{Binding DataContext.Viewport.ActiveShaderMode,
                                                     RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                     Converter={StaticResource EnumMatchCvt}, ConverterParameter=Clay}"
                                    Command="{Binding DataContext.Viewport.SetShaderModeCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="Clay">
                                <Button.Background>
                                    <RadialGradientBrush Center="38%,35%" GradientOrigin="38%,35%" RadiusX="70%" RadiusY="70%">
                                        <GradientStop Color="#d4956a" Offset="0"/>
                                        <GradientStop Color="#a0522d" Offset="0.55"/>
                                        <GradientStop Color="#3d1a08" Offset="1"/>
                                    </RadialGradientBrush>
                                </Button.Background>
                            </Button>

                            <Button Classes="ShaderSphereBtn" Margin="3"
                                    ToolTip.Tip="Arctic — Rhino-style white clay presentation"
                                    Classes.active="{Binding DataContext.Viewport.ActiveShaderMode,
                                                     RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                     Converter={StaticResource EnumMatchCvt}, ConverterParameter=Arctic}"
                                    Command="{Binding DataContext.Viewport.SetShaderModeCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="Arctic">
                                <Button.Background>
                                    <RadialGradientBrush Center="38%,35%" GradientOrigin="38%,35%" RadiusX="70%" RadiusY="70%">
                                        <GradientStop Color="#ffffff" Offset="0"/>
                                        <GradientStop Color="#e8e8ec" Offset="0.45"/>
                                        <GradientStop Color="#b8bcc4" Offset="0.78"/>
                                        <GradientStop Color="#f4f4f6" Offset="1"/>
                                    </RadialGradientBrush>
                                </Button.Background>
                            </Button>

                            <Button Classes="ShaderSphereBtn" Margin="3"
                                    ToolTip.Tip="Metal"
                                    Classes.active="{Binding DataContext.Viewport.ActiveShaderMode,
                                                     RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                     Converter={StaticResource EnumMatchCvt}, ConverterParameter=Metal}"
                                    Command="{Binding DataContext.Viewport.SetShaderModeCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="Metal">
                                <Button.Background>
                                    <RadialGradientBrush Center="38%,35%" GradientOrigin="38%,35%" RadiusX="70%" RadiusY="70%">
                                        <GradientStop Color="#f0f0f0" Offset="0"/>
                                        <GradientStop Color="#909090" Offset="0.40"/>
                                        <GradientStop Color="#202020" Offset="0.75"/>
                                        <GradientStop Color="#707070" Offset="1"/>
                                    </RadialGradientBrush>
                                </Button.Background>
                            </Button>

                            <Button Classes="ShaderSphereBtn" Margin="3"
                                    ToolTip.Tip="Chrome"
                                    Classes.active="{Binding DataContext.Viewport.ActiveShaderMode,
                                                     RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                     Converter={StaticResource EnumMatchCvt}, ConverterParameter=Chrome}"
                                    Command="{Binding DataContext.Viewport.SetShaderModeCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="Chrome">
                                <Button.Background>
                                    <RadialGradientBrush Center="38%,35%" GradientOrigin="38%,35%" RadiusX="70%" RadiusY="70%">
                                        <GradientStop Color="#ffffff" Offset="0"/>
                                        <GradientStop Color="#ffffff" Offset="0.15"/>
                                        <GradientStop Color="#555555" Offset="0.40"/>
                                        <GradientStop Color="#eeeeee" Offset="0.60"/>
                                        <GradientStop Color="#333333" Offset="0.80"/>
                                        <GradientStop Color="#aaaaaa" Offset="1"/>
                                    </RadialGradientBrush>
                                </Button.Background>
                            </Button>

                            <Button Classes="ShaderSphereBtn" Margin="3"
                                    ToolTip.Tip="Matte Black"
                                    Classes.active="{Binding DataContext.Viewport.ActiveShaderMode,
                                                     RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                     Converter={StaticResource EnumMatchCvt}, ConverterParameter=MatteBlack}"
                                    Command="{Binding DataContext.Viewport.SetShaderModeCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="MatteBlack">
                                <Button.Background>
                                    <RadialGradientBrush Center="38%,35%" GradientOrigin="38%,35%" RadiusX="70%" RadiusY="70%">
                                        <GradientStop Color="#444444" Offset="0"/>
                                        <GradientStop Color="#111111" Offset="0.55"/>
                                        <GradientStop Color="#000000" Offset="1"/>
                                    </RadialGradientBrush>
                                </Button.Background>
                            </Button>

                            <Button Classes="ShaderSphereBtn" Margin="3"
                                    ToolTip.Tip="Purple"
                                    Classes.active="{Binding DataContext.Viewport.ActiveShaderMode,
                                                     RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                     Converter={StaticResource EnumMatchCvt}, ConverterParameter=Purple}"
                                    Command="{Binding DataContext.Viewport.SetShaderModeCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="Purple">
                                <Button.Background>
                                    <RadialGradientBrush Center="38%,35%" GradientOrigin="38%,35%" RadiusX="70%" RadiusY="70%">
                                        <GradientStop Color="#c8a0f0" Offset="0"/>
                                        <GradientStop Color="#7030c0" Offset="0.55"/>
                                        <GradientStop Color="#1a0040" Offset="1"/>
                                    </RadialGradientBrush>
                                </Button.Background>
                            </Button>

                            <Button Classes="ShaderSphereBtn" Margin="3"
                                    ToolTip.Tip="Normals"
                                    Classes.active="{Binding DataContext.Viewport.ActiveShaderMode,
                                                     RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                     Converter={StaticResource EnumMatchCvt}, ConverterParameter=Normals}"
                                    Command="{Binding DataContext.Viewport.SetShaderModeCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="Normals">
                                <Button.Background>
                                    <RadialGradientBrush Center="38%,35%" GradientOrigin="38%,35%" RadiusX="70%" RadiusY="70%">
                                        <GradientStop Color="#ff9090" Offset="0"/>
                                        <GradientStop Color="#8888ff" Offset="0.50"/>
                                        <GradientStop Color="#22cc88" Offset="1"/>
                                    </RadialGradientBrush>
                                </Button.Background>
                            </Button>

                        </WrapPanel>

                        <!-- Material channels — inspector debug views of the selected mesh's PBR maps. -->
                        <Border Height="1" Background="{DynamicResource Border1}" Margin="0,10,0,10"/>
                        <TextBlock Text="MATERIAL CHANNELS" Classes="SectionHeader" Margin="0,0,0,6"/>
                        <WrapPanel>
                            <Button Classes="ToolbarButton" Margin="0,0,4,4" Content="Base Color"
                                    Classes.active="{Binding DataContext.Viewport.ActiveShaderMode,
                                                     RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                     Converter={StaticResource EnumMatchCvt}, ConverterParameter=BaseColor}"
                                    Command="{Binding DataContext.Viewport.SetShaderModeCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="BaseColor"/>
                            <Button Classes="ToolbarButton" Margin="0,0,4,4" Content="Metalness"
                                    Classes.active="{Binding DataContext.Viewport.ActiveShaderMode,
                                                     RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                     Converter={StaticResource EnumMatchCvt}, ConverterParameter=Metalness}"
                                    Command="{Binding DataContext.Viewport.SetShaderModeCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="Metalness"/>
                            <Button Classes="ToolbarButton" Margin="0,0,4,4" Content="Roughness"
                                    Classes.active="{Binding DataContext.Viewport.ActiveShaderMode,
                                                     RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                     Converter={StaticResource EnumMatchCvt}, ConverterParameter=Roughness}"
                                    Command="{Binding DataContext.Viewport.SetShaderModeCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="Roughness"/>
                            <Button Classes="ToolbarButton" Margin="0,0,4,4" Content="Normal"
                                    Classes.active="{Binding DataContext.Viewport.ActiveShaderMode,
                                                     RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                     Converter={StaticResource EnumMatchCvt}, ConverterParameter=NormalMap}"
                                    Command="{Binding DataContext.Viewport.SetShaderModeCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="NormalMap"/>
                            <Button Classes="ToolbarButton" Margin="0,0,4,4" Content="AO"
                                    Classes.active="{Binding DataContext.Viewport.ActiveShaderMode,
                                                     RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                     Converter={StaticResource EnumMatchCvt}, ConverterParameter=AO}"
                                    Command="{Binding DataContext.Viewport.SetShaderModeCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="AO"/>
                            <Button Classes="ToolbarButton" Margin="0,0,4,4" Content="Emission"
                                    Classes.active="{Binding DataContext.Viewport.ActiveShaderMode,
                                                     RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                     Converter={StaticResource EnumMatchCvt}, ConverterParameter=Emission}"
                                    Command="{Binding DataContext.Viewport.SetShaderModeCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="Emission"/>
                            <Button Classes="ToolbarButton" Margin="0,0,4,4" Content="UV Checker"
                                    Classes.active="{Binding DataContext.Viewport.ActiveShaderMode,
                                                     RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                     Converter={StaticResource EnumMatchCvt}, ConverterParameter=UvChecker}"
                                    Command="{Binding DataContext.Viewport.SetShaderModeCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="UvChecker"/>
                            <Button Classes="ToolbarButton" Margin="0,0,4,4" Content="Wireframe"
                                    Classes.active="{Binding DataContext.Viewport.ActiveShaderMode,
                                                     RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                     Converter={StaticResource EnumMatchCvt}, ConverterParameter=Wireframe}"
                                    Command="{Binding DataContext.Viewport.SetShaderModeCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="Wireframe"
                                    ToolTip.Tip="Flat-shaded polygonal mesh with wireframe overlay"/>
                        </WrapPanel>

                        <!-- Lighting -->
                        <Border Height="1" Background="{DynamicResource Border1}" Margin="0,10,0,10"/>
                        <TextBlock Text="LIGHTING" Classes="SectionHeader" Margin="0,0,0,6"/>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Azimuth" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="360" VerticalAlignment="Center"
                                    Value="{Binding DataContext.Viewport.LightAzimuth,
                                            RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"
                                    ToolTip.Tip="Light azimuth (horizontal rotation)"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Elevation" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="90" VerticalAlignment="Center"
                                    Value="{Binding DataContext.Viewport.LightElevation,
                                            RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"
                                    ToolTip.Tip="Light elevation (vertical angle)"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Intensity" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="2" VerticalAlignment="Center"
                                    Value="{Binding DataContext.Viewport.LightIntensity,
                                            RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"
                                    ToolTip.Tip="Light intensity"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Exposure" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0.4" Maximum="2.5" VerticalAlignment="Center"
                                    Value="{Binding DataContext.Viewport.Exposure,
                                            RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"
                                    ToolTip.Tip="Final-render exposure (pre-tonemap)"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Reflections" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="3" VerticalAlignment="Center"
                                    Value="{Binding DataContext.Viewport.IblIntensity,
                                            RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"
                                    ToolTip.Tip="Environment reflection / IBL gain"/>
                        </Grid>

                        <!-- Cavity (Blender-style viewport shading) -->
                        <Border Height="1" Background="{DynamicResource Border1}" Margin="0,10,0,10"/>
                        <TextBlock Text="CAVITY" Classes="SectionHeader" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"
                                      IsChecked="{Binding DataContext.Viewport.CavityEnabled,
                                                  RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"
                                      ToolTip.Tip="Accentuate ridges and valleys for form readability"/>
                            <TextBlock Grid.Column="1" Text="Cavity" Foreground="{DynamicResource TextPrimary}" FontSize="12" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Type" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox MinWidth="72" FontSize="11"
                                          ItemsSource="{Binding DataContext.Viewport.CavityModeOptions,
                                                        RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                          SelectedItem="{Binding DataContext.Viewport.CavityModeOption,
                                                         RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="World Space" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,2"/>
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="44"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Ridge" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                                <Slider Grid.Column="1" Minimum="0" Maximum="2" VerticalAlignment="Center"
                                        Value="{Binding DataContext.Viewport.CavityWorldRidge,
                                                RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"/>
                            </Grid>
                            <Grid Grid.Column="2">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="44"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Valley" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                                <Slider Grid.Column="1" Minimum="0" Maximum="2" VerticalAlignment="Center"
                                        Value="{Binding DataContext.Viewport.CavityWorldValley,
                                                RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"/>
                            </Grid>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Distance" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center"
                                       ToolTip.Tip="World-space sampling radius (mm)"/>
                            <Slider Grid.Column="1" Minimum="0.5" Maximum="50" VerticalAlignment="Center"
                                    Value="{Binding DataContext.Viewport.CavityWorldDistance,
                                            RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"/>
                        </Grid>
                        <TextBlock Text="Screen Space" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,2"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="44"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Ridge" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                                <Slider Grid.Column="1" Minimum="0" Maximum="2" VerticalAlignment="Center"
                                        Value="{Binding DataContext.Viewport.CavityScreenRidge,
                                                RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"/>
                            </Grid>
                            <Grid Grid.Column="2">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="44"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Valley" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                                <Slider Grid.Column="1" Minimum="0" Maximum="2" VerticalAlignment="Center"
                                        Value="{Binding DataContext.Viewport.CavityScreenValley,
                                                RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"/>
                            </Grid>
                        </Grid>

                        <!-- Contact shadows -->
                        <Border Height="1" Background="{DynamicResource Border1}" Margin="0,10,0,10"/>
                        <TextBlock Text="SHADOWS" Classes="SectionHeader" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Contact shadows" Foreground="{DynamicResource TextPrimary}" FontSize="12" VerticalAlignment="Center"/>
                            <CheckBox  Grid.Column="1" VerticalAlignment="Center"
                                       IsChecked="{Binding DataContext.Viewport.ShowContactShadows,
                                                   RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"
                                       ToolTip.Tip="Soft multiply shadows under bed, pedestal, and objects"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Size" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0.25" Maximum="3" VerticalAlignment="Center"
                                    Value="{Binding DataContext.Viewport.ContactShadowSize,
                                            RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"
                                    ToolTip.Tip="Shadow spread (1 = default; higher = larger/softer)"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Darkness" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="2" VerticalAlignment="Center"
                                    Value="{Binding DataContext.Viewport.ContactShadowDarkness,
                                            RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"
                                    ToolTip.Tip="Shadow strength (1 = default; 0 = off; higher = darker)"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Blur" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="3" VerticalAlignment="Center"
                                    Value="{Binding DataContext.Viewport.ContactShadowBlur,
                                            RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"
                                    ToolTip.Tip="Shadow edge softness (1 = default; 0 = sharp; higher = softer)"/>
                        </Grid>

                        <!-- Visibility toggles -->
                        <Border Height="1" Background="{DynamicResource Border1}" Margin="0,10,0,10"/>
                        <TextBlock Text="VISIBILITY" Classes="SectionHeader" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Grid"     Foreground="{DynamicResource TextPrimary}" FontSize="12" VerticalAlignment="Center"/>
                            <CheckBox  Grid.Column="1" VerticalAlignment="Center"
                                       IsChecked="{Binding DataContext.Viewport.ShowGrid,
                                                   RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Axes"     Foreground="{DynamicResource TextPrimary}" FontSize="12" VerticalAlignment="Center"/>
                            <CheckBox  Grid.Column="1" VerticalAlignment="Center"
                                       IsChecked="{Binding DataContext.Viewport.ShowAxes,
                                                   RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Bed grid" Foreground="{DynamicResource TextPrimary}" FontSize="12" VerticalAlignment="Center"/>
                            <CheckBox  Grid.Column="1" VerticalAlignment="Center"
                                       IsChecked="{Binding DataContext.Viewport.ShowBedGrid,
                                                   RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"/>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>

                <!-- Robot tab -->
                <ScrollViewer IsVisible="{Binding IsRobotTabActive}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,8">

                        <TextBlock Text="TOOL" Classes="SectionHeader"/>
                        <ComboBox Margin="8,0,8,8"
                                  ItemsSource="{Binding DataContext.RightPanel.Settings.Robot.ToolNames,
                                                RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                  SelectedIndex="{Binding DataContext.RightPanel.Settings.Robot.SelectedToolIndex,
                                                  RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                  Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"/>

                        <Border Height="1" Background="{DynamicResource Border1}" Margin="8,4"/>
                        <TextBlock Text="JOINT ANGLES" Classes="SectionHeader"/>

                        <!-- A1 -->
                        <Grid Margin="8,4,8,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="56"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="A1" Classes="LabelMuted" VerticalAlignment="Center"/>
                            <Slider    Grid.Column="1"
                                       Minimum="{Binding DataContext.RightPanel.Settings.Robot.MinA1, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                       Maximum="{Binding DataContext.RightPanel.Settings.Robot.MaxA1, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                       Value="{Binding DataContext.RightPanel.Settings.Robot.A1, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"
                                       VerticalAlignment="Center"/>
                            <TextBox   Grid.Column="2" Classes="PanelTextBox"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.A1, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay, StringFormat={}{0:F2}}"
                                       TextAlignment="Right" Padding="4,2" VerticalContentAlignment="Center"
                                       KeyDown="JointAngle_KeyDown"/>
                        </Grid>

                        <!-- A2 -->
                        <Grid Margin="8,2,8,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="56"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="A2" Classes="LabelMuted" VerticalAlignment="Center"/>
                            <Slider    Grid.Column="1"
                                       Minimum="{Binding DataContext.RightPanel.Settings.Robot.MinA2, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                       Maximum="{Binding DataContext.RightPanel.Settings.Robot.MaxA2, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                       Value="{Binding DataContext.RightPanel.Settings.Robot.A2, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"
                                       VerticalAlignment="Center"/>
                            <TextBox   Grid.Column="2" Classes="PanelTextBox"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.A2, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay, StringFormat={}{0:F2}}"
                                       TextAlignment="Right" Padding="4,2" VerticalContentAlignment="Center"
                                       KeyDown="JointAngle_KeyDown"/>
                        </Grid>

                        <!-- A3 -->
                        <Grid Margin="8,2,8,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="56"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="A3" Classes="LabelMuted" VerticalAlignment="Center"/>
                            <Slider    Grid.Column="1"
                                       Minimum="{Binding DataContext.RightPanel.Settings.Robot.MinA3, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                       Maximum="{Binding DataContext.RightPanel.Settings.Robot.MaxA3, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                       Value="{Binding DataContext.RightPanel.Settings.Robot.A3, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"
                                       VerticalAlignment="Center"/>
                            <TextBox   Grid.Column="2" Classes="PanelTextBox"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.A3, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay, StringFormat={}{0:F2}}"
                                       TextAlignment="Right" Padding="4,2" VerticalContentAlignment="Center"
                                       KeyDown="JointAngle_KeyDown"/>
                        </Grid>

                        <!-- A4 -->
                        <Grid Margin="8,2,8,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="56"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="A4" Classes="LabelMuted" VerticalAlignment="Center"/>
                            <Slider    Grid.Column="1"
                                       Minimum="{Binding DataContext.RightPanel.Settings.Robot.MinA4, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                       Maximum="{Binding DataContext.RightPanel.Settings.Robot.MaxA4, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                       Value="{Binding DataContext.RightPanel.Settings.Robot.A4, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"
                                       VerticalAlignment="Center"/>
                            <TextBox   Grid.Column="2" Classes="PanelTextBox"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.A4, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay, StringFormat={}{0:F2}}"
                                       TextAlignment="Right" Padding="4,2" VerticalContentAlignment="Center"
                                       KeyDown="JointAngle_KeyDown"/>
                        </Grid>

                        <!-- A5 -->
                        <Grid Margin="8,2,8,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="56"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="A5" Classes="LabelMuted" VerticalAlignment="Center"/>
                            <Slider    Grid.Column="1"
                                       Minimum="{Binding DataContext.RightPanel.Settings.Robot.MinA5, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                       Maximum="{Binding DataContext.RightPanel.Settings.Robot.MaxA5, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                       Value="{Binding DataContext.RightPanel.Settings.Robot.A5, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"
                                       VerticalAlignment="Center"/>
                            <TextBox   Grid.Column="2" Classes="PanelTextBox"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.A5, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay, StringFormat={}{0:F2}}"
                                       TextAlignment="Right" Padding="4,2" VerticalContentAlignment="Center"
                                       KeyDown="JointAngle_KeyDown"/>
                        </Grid>

                        <!-- A6 -->
                        <Grid Margin="8,2,8,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="56"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="A6" Classes="LabelMuted" VerticalAlignment="Center"/>
                            <Slider    Grid.Column="1"
                                       Minimum="{Binding DataContext.RightPanel.Settings.Robot.MinA6, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                       Maximum="{Binding DataContext.RightPanel.Settings.Robot.MaxA6, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                       Value="{Binding DataContext.RightPanel.Settings.Robot.A6, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"
                                       VerticalAlignment="Center"/>
                            <TextBox   Grid.Column="2" Classes="PanelTextBox"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.A6, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay, StringFormat={}{0:F2}}"
                                       TextAlignment="Right" Padding="4,2" VerticalContentAlignment="Center"
                                       KeyDown="JointAngle_KeyDown"/>
                        </Grid>

                        <!-- E1 — rotary bed (external axis) -->
                        <Border Height="1" Background="{DynamicResource Border1}" Margin="8,2,8,4"
                                ToolTip.Tip="External axis 1: rotary print bed"/>
                        <Grid Margin="8,2,8,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="56"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="E1" Classes="LabelMuted" VerticalAlignment="Center"
                                       ToolTip.Tip="Rotary bed (external axis 1), KRL degrees"/>
                            <Slider    Grid.Column="1"
                                       Minimum="{Binding DataContext.RightPanel.Settings.Robot.MinE1, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                       Maximum="{Binding DataContext.RightPanel.Settings.Robot.MaxE1, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                       Value="{Binding DataContext.RightPanel.Settings.Robot.E1, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"
                                       VerticalAlignment="Center"/>
                            <TextBox   Grid.Column="2" Classes="PanelTextBox"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.E1, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay, StringFormat={}{0:F2}}"
                                       TextAlignment="Right" Padding="4,2" VerticalContentAlignment="Center"
                                       KeyDown="JointAngle_KeyDown"/>
                        </Grid>

                        <Button Content="GO TO BED CENTER"
                                Command="{Binding DataContext.RightPanel.Settings.Robot.GoToBedCenterCommand,
                                          RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                Classes="PrimaryButton"
                                HorizontalAlignment="Stretch"
                                Margin="8,4,8,8"/>

                        <!-- All bed settings (manual adjust + calibration) grouped, collapsed by default. -->
                        <Expander Classes="SectionExpander" Header="BED SETTINGS" IsExpanded="False" Margin="0,4,0,0">
                          <StackPanel>

                        <!-- Rotary bed manual adjust (rotary cells only) -->
                        <StackPanel IsVisible="{Binding DataContext.RightPanel.Settings.Robot.IsRotaryBed,
                                                RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
                            <Border Height="1" Background="{DynamicResource Border1}" Margin="8,4"/>
                            <TextBlock Text="ROTARY BED" Classes="SectionHeader"/>
                            <TextBlock Text="Centre / height of the turntable axis (world mm) and grid diameter. Edits apply live and save to the cell."
                                       TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}"
                                       FontSize="11" Margin="8,2,8,6"/>

                            <Grid Margin="8,2,8,2" ColumnDefinitions="70,*">
                                <TextBlock Grid.Column="0" Text="Centre X" Classes="LabelMuted" VerticalAlignment="Center"/>
                                <TextBox   Grid.Column="1" Classes="PanelTextBox" Padding="4,2" VerticalContentAlignment="Center"
                                           Text="{Binding DataContext.RightPanel.Settings.Robot.BedCenterX,
                                                  RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay, StringFormat={}{0:F2}}"/>
                            </Grid>
                            <Grid Margin="8,2,8,2" ColumnDefinitions="70,*">
                                <TextBlock Grid.Column="0" Text="Centre Y" Classes="LabelMuted" VerticalAlignment="Center"/>
                                <TextBox   Grid.Column="1" Classes="PanelTextBox" Padding="4,2" VerticalContentAlignment="Center"
                                           Text="{Binding DataContext.RightPanel.Settings.Robot.BedCenterY,
                                                  RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay, StringFormat={}{0:F2}}"/>
                            </Grid>
                            <Grid Margin="8,2,8,2" ColumnDefinitions="70,*">
                                <TextBlock Grid.Column="0" Text="Height Z" Classes="LabelMuted" VerticalAlignment="Center"/>
                                <TextBox   Grid.Column="1" Classes="PanelTextBox" Padding="4,2" VerticalContentAlignment="Center"
                                           Text="{Binding DataContext.RightPanel.Settings.Robot.BedCenterZ,
                                                  RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay, StringFormat={}{0:F2}}"/>
                            </Grid>
                            <Grid Margin="8,2,8,2" ColumnDefinitions="70,*">
                                <TextBlock Grid.Column="0" Text="Diameter" Classes="LabelMuted" VerticalAlignment="Center"
                                           ToolTip.Tip="Rotary grid diameter (mm). 1828.8 = 6 ft."/>
                                <TextBox   Grid.Column="1" Classes="PanelTextBox" Padding="4,2" VerticalContentAlignment="Center"
                                           Text="{Binding DataContext.RightPanel.Settings.Robot.BedDiameter,
                                                  RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay, StringFormat={}{0:F1}}"/>
                            </Grid>
                            <Grid Margin="8,2,8,4" ColumnDefinitions="70,*">
                                <TextBlock Grid.Column="0" Text="E1 angle" Classes="LabelMuted" VerticalAlignment="Center"
                                           ToolTip.Tip="Current rotary bed rotation (KRL degrees)."/>
                                <TextBox   Grid.Column="1" Classes="PanelTextBox" Padding="4,2" VerticalContentAlignment="Center"
                                           Text="{Binding DataContext.RightPanel.Settings.Robot.E1,
                                                  RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay, StringFormat={}{0:F2}}"/>
                            </Grid>
                            <CheckBox Margin="8,2,8,4"
                                      Content="Reverse E1 rotation (CW)"
                                      ToolTip.Tip="Direction E1 spins scene geometry about the centre. Set automatically by rotation calibration."
                                      IsChecked="{Binding DataContext.RightPanel.Settings.Robot.IsE1Reversed,
                                                  RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"/>
                            <Grid Margin="8,2,8,4" ColumnDefinitions="70,*">
                                <TextBlock Grid.Column="0" Text="Orient °" Classes="LabelMuted" VerticalAlignment="Center"
                                           ToolTip.Tip="Hole-grid phase offset (bed-orient). Normally set by bed-cal; default −0.97°."/>
                                <TextBox   Grid.Column="1" Classes="PanelTextBox" Padding="4,2" VerticalContentAlignment="Center"
                                           Text="{Binding DataContext.RightPanel.Settings.Robot.BedOrientationOffsetDeg,
                                                  RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay, StringFormat={}{0:F2}}"
                                           PlaceholderText="-0.97"/>
                            </Grid>
                        </StackPanel>

                        <!-- Rotary bed (E1) axis calibration -->
                        <Border Height="1" Background="{DynamicResource Border1}" Margin="8,4"/>
                        <TextBlock Text="ROTARY BED CALIBRATION" Classes="SectionHeader"/>
                        <TextBlock Text="Tape the calibration board off-centre on the bed. Rotate E1 and capture across the widest range you can (keep the arm still)."
                                   TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11" Margin="8,2,8,6"/>

                        <Button Content="AUTO-CALIBRATE (E1 SWEEP)"
                                Command="{Binding DataContext.RightPanel.Settings.Robot.BedCalibration.AutoCalibrateCommand,
                                          RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                Classes="PrimaryButton" HorizontalAlignment="Stretch" Margin="8,0,8,4"
                                ToolTip.Tip="Starts BED_SCAN_CAL on the controller via the C3 Bridge (no pendant Start). The robot sweeps E1 -180..180 in 10 stops; the app captures a scan at each, then fits the result."/>
                        <TextBlock Text="Auto: robot synced + in AUTO mode with drives on. The app starts the program and scans automatically. Or collect samples manually below."
                                   TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11" Margin="8,0,8,6"/>

                        <Grid Margin="8,0,8,4" ColumnDefinitions="*,*">
                            <Button Grid.Column="0" Content="ADD SAMPLE"
                                    Command="{Binding DataContext.RightPanel.Settings.Robot.BedCalibration.AddSampleCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    Classes="PrimaryButton" HorizontalAlignment="Stretch" Margin="0,0,4,0"/>
                            <Button Grid.Column="1" Content="CLEAR"
                                    Command="{Binding DataContext.RightPanel.Settings.Robot.BedCalibration.ClearCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    HorizontalAlignment="Stretch" Margin="4,0,0,0"/>
                        </Grid>

                        <TextBlock Text="{Binding DataContext.RightPanel.Settings.Robot.BedCalibration.SampleCountLabel,
                                          RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="8,0,8,4"/>

                        <Button Content="COMPUTE BED CENTRE"
                                Command="{Binding DataContext.RightPanel.Settings.Robot.BedCalibration.ComputeCommand,
                                          RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                Classes="PrimaryButton" HorizontalAlignment="Stretch" Margin="8,0,8,6"/>

                        <Grid Margin="8,0,8,2"
                              IsVisible="{Binding DataContext.RightPanel.Settings.Robot.BedCalibration.HasResult,
                                          RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                              ColumnDefinitions="90,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Centre X" Classes="LabelMuted"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Classes="LabelMuted"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.BedCalibration.CenterX,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}, StringFormat={}{0:F1} mm}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Centre Y" Classes="LabelMuted"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Classes="LabelMuted"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.BedCalibration.CenterY,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}, StringFormat={}{0:F1} mm}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Height Z" Classes="LabelMuted"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Classes="LabelMuted"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.BedCalibration.CenterZ,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}, StringFormat={}{0:F1} mm}"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Radius" Classes="LabelMuted"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Classes="LabelMuted"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.BedCalibration.Radius,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}, StringFormat={}{0:F0} mm}"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Residual" Classes="LabelMuted"
                                       ToolTip.Tip="RMS radial fit error. Under ~1–2 mm is good; large values mean a slipped board or the arm moved."/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Classes="LabelMuted"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.BedCalibration.Residual,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}, StringFormat={}{0:F2} mm}"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Z-spread" Classes="LabelMuted"
                                       ToolTip.Tip="Max−min sample height. Small = near-vertical axis on a flat bed; large = axis tilt."/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Classes="LabelMuted"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.BedCalibration.ZSpread,
                                              RelativeSource={RelativeSource AncestorType={x:Type Window}}, StringFormat={}{0:F2} mm}"/>
                        </Grid>

                        <TextBlock Margin="8,0,8,2" TextWrapping="Wrap" FontSize="11"
                                   Foreground="{DynamicResource TextSecondary}"
                                   IsVisible="{Binding DataContext.RightPanel.Settings.Robot.BedCalibration.HasResult,
                                               RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                   Text="{Binding DataContext.RightPanel.Settings.Robot.BedCalibration.RotationLabel,
                                          RelativeSource={RelativeSource AncestorType={x:Type Window}}}"/>

                        <Button Content="{Binding DataContext.RightPanel.Settings.Robot.BedCalibration.ApplyButtonLabel,
                                          RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                Command="{Binding DataContext.RightPanel.Settings.Robot.BedCalibration.ApplyCommand,
                                          RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                Classes="PrimaryButton" HorizontalAlignment="Stretch" Margin="8,4,8,4"
                                IsVisible="{Binding DataContext.RightPanel.Settings.Robot.BedCalibration.HasResult,
                                            RelativeSource={RelativeSource AncestorType={x:Type Window}}}"/>

                        <TextBlock Text="{Binding DataContext.RightPanel.Settings.Robot.BedCalibration.Status,
                                          RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                   TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11" Margin="8,2,8,8"/>
                          </StackPanel>
                        </Expander>

                        <Border Height="1" Background="{DynamicResource Border1}" Margin="8,4"/>
                        <TextBlock Text="HOME POSITIONS" Classes="SectionHeader"/>
                        <TextBox Margin="8,0,8,4"
                                 Classes="PanelTextBox"
                                 Text="{Binding DataContext.RightPanel.Settings.Robot.NewHomePositionName,
                                        RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"
                                 PlaceholderText="Home Target..."
                                 VerticalContentAlignment="Center"
                                 Padding="6,4"/>
                        <Button Content="SAVE AS HOME POSITION"
                                Command="{Binding DataContext.RightPanel.Settings.Robot.SaveAsHomePositionCommand,
                                          RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                HorizontalAlignment="Stretch"
                                Margin="8,0,8,8"/>

                        <Border Height="1" Background="{DynamicResource Border1}" Margin="8,4"/>

                        <!-- Flange position readout -->
                        <TextBlock Text="FLANGE POSITION (ROBROOT)" Classes="SectionHeader"/>
                        <Grid Margin="8,4,8,2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="X" Classes="LabelMuted" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Classes="LabelMuted"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.FlangeX, RelativeSource={RelativeSource AncestorType={x:Type Window}}, StringFormat={}{0:F1} mm}"/>
                        </Grid>
                        <Grid Margin="8,2,8,2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Y" Classes="LabelMuted" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Classes="LabelMuted"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.FlangeY, RelativeSource={RelativeSource AncestorType={x:Type Window}}, StringFormat={}{0:F1} mm}"/>
                        </Grid>
                        <Grid Margin="8,2,8,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Z" Classes="LabelMuted" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Classes="LabelMuted"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.FlangeZ, RelativeSource={RelativeSource AncestorType={x:Type Window}}, StringFormat={}{0:F1} mm}"/>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource Border1}" Margin="8,4"/>

                        <!-- TCP world position readout -->
                        <TextBlock Text="TCP WORLD POSITION" Classes="SectionHeader"/>
                        <Grid Margin="8,4,8,2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="X" Classes="LabelMuted" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Classes="LabelMuted"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.TcpX, RelativeSource={RelativeSource AncestorType={x:Type Window}}, StringFormat={}{0:F1} mm}"/>
                        </Grid>
                        <Grid Margin="8,2,8,2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Y" Classes="LabelMuted" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Classes="LabelMuted"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.TcpY, RelativeSource={RelativeSource AncestorType={x:Type Window}}, StringFormat={}{0:F1} mm}"/>
                        </Grid>
                        <Grid Margin="8,2,8,2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Z" Classes="LabelMuted" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Classes="LabelMuted"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.TcpZ, RelativeSource={RelativeSource AncestorType={x:Type Window}}, StringFormat={}{0:F1} mm}"/>
                        </Grid>
                        <Grid Margin="8,2,8,2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="A" Classes="LabelMuted" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Classes="LabelMuted"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.TcpA, RelativeSource={RelativeSource AncestorType={x:Type Window}}, StringFormat={}{0:F1}°}"/>
                        </Grid>
                        <Grid Margin="8,2,8,2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="B" Classes="LabelMuted" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Classes="LabelMuted"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.TcpB, RelativeSource={RelativeSource AncestorType={x:Type Window}}, StringFormat={}{0:F1}°}"/>
                        </Grid>
                        <Grid Margin="8,2,8,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="C" Classes="LabelMuted" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Classes="LabelMuted"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.TcpC, RelativeSource={RelativeSource AncestorType={x:Type Window}}, StringFormat={}{0:F1}°}"/>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource Border1}" Margin="8,4"/>

                        <!-- BASE frame (from cell config) -->
                        <TextBlock Text="BASE FRAME (ROBROOT)" Classes="SectionHeader"/>
                        <Grid Margin="8,4,8,2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="X" Classes="LabelMuted" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Classes="LabelMuted"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.BaseX, RelativeSource={RelativeSource AncestorType={x:Type Window}}, StringFormat={}{0:F2} mm}"/>
                        </Grid>
                        <Grid Margin="8,2,8,2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Y" Classes="LabelMuted" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Classes="LabelMuted"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.BaseY, RelativeSource={RelativeSource AncestorType={x:Type Window}}, StringFormat={}{0:F2} mm}"/>
                        </Grid>
                        <Grid Margin="8,2,8,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Z" Classes="LabelMuted" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Classes="LabelMuted"
                                       Text="{Binding DataContext.RightPanel.Settings.Robot.BaseZ, RelativeSource={RelativeSource AncestorType={x:Type Window}}, StringFormat={}{0:F2} mm}"/>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource Border1}" Margin="8,4"/>

                        <!-- KRL frame dropdowns -->
                        <TextBlock Text="ROBOT FRAMES" Classes="SectionHeader"/>
                        <TextBlock Text="TOOL" Classes="LabelMuted" Margin="8,4,8,2"/>
                        <ComboBox Margin="8,0,8,6" HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding DataContext.RightPanel.Settings.Robot.KrlToolOptions,
                                               RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                  SelectedIndex="{Binding DataContext.RightPanel.Settings.Robot.KrlToolSelectedIndex,
                                                  RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                  Mode=TwoWay}"/>
                        <TextBlock Text="BASE" Classes="LabelMuted" Margin="8,4,8,2"/>
                        <ComboBox Margin="8,0,8,8" HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding DataContext.RightPanel.Settings.Robot.KrlBaseOptions,
                                               RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                  SelectedIndex="{Binding DataContext.RightPanel.Settings.Robot.KrlBaseSelectedIndex,
                                                  RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                                  Mode=TwoWay}"/>

                        <Border Height="1" Background="{DynamicResource Border1}" Margin="8,4"/>
                        <TextBlock Text="TCP OFFSET" Classes="SectionHeader"/>

                        <!-- Position X Y Z -->
                        <Grid Margin="8,2,8,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="X" Classes="LabelMuted" VerticalAlignment="Center"/>
                            <NumericUpDown Grid.Column="1" FontSize="11" FormatString="F2" Increment="0.1"
                                           Value="{Binding DataContext.RightPanel.Settings.Robot.EditTcpX,
                                                   RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"/>
                            <TextBlock Grid.Column="2" Text="Y" Classes="LabelMuted" VerticalAlignment="Center" Margin="6,0,0,0"/>
                            <NumericUpDown Grid.Column="3" FontSize="11" FormatString="F2" Increment="0.1"
                                           Value="{Binding DataContext.RightPanel.Settings.Robot.EditTcpY,
                                                   RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"/>
                            <TextBlock Grid.Column="4" Text="Z" Classes="LabelMuted" VerticalAlignment="Center" Margin="6,0,0,0"/>
                            <NumericUpDown Grid.Column="5" FontSize="11" FormatString="F2" Increment="0.1"
                                           Value="{Binding DataContext.RightPanel.Settings.Robot.EditTcpZ,
                                                   RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"/>
                        </Grid>

                        <!-- Rotation A B C -->
                        <Grid Margin="8,2,8,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="A" Classes="LabelMuted" VerticalAlignment="Center"/>
                            <NumericUpDown Grid.Column="1" FontSize="11" FormatString="F2" Increment="0.1"
                                           Value="{Binding DataContext.RightPanel.Settings.Robot.EditTcpA,
                                                   RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"/>
                            <TextBlock Grid.Column="2" Text="B" Classes="LabelMuted" VerticalAlignment="Center" Margin="6,0,0,0"/>
                            <NumericUpDown Grid.Column="3" FontSize="11" FormatString="F2" Increment="0.1"
                                           Value="{Binding DataContext.RightPanel.Settings.Robot.EditTcpB,
                                                   RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"/>
                            <TextBlock Grid.Column="4" Text="C" Classes="LabelMuted" VerticalAlignment="Center" Margin="6,0,0,0"/>
                            <NumericUpDown Grid.Column="5" FontSize="11" FormatString="F2" Increment="0.1"
                                           Value="{Binding DataContext.RightPanel.Settings.Robot.EditTcpC,
                                                   RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"/>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Grid>
    </Border>

</UserControl>
