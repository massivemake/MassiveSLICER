<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ia="https://github.com/projektanker/icons.avalonia">

    <!-- ── TextBlock ──────────────────────────────────────────────────────── -->
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontSize"   Value="12"/>
    </Style>
    <Style Selector="TextBlock.LabelMuted">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="FontSize"   Value="11"/>
    </Style>
    <Style Selector="TextBlock.Readout">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontFamily" Value="Consolas, Courier New, monospace"/>
        <Setter Property="FontSize"   Value="12"/>
    </Style>
    <Style Selector="TextBlock.SectionHeader">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="FontSize"   Value="10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin"     Value="8,10,8,4"/>
    </Style>

    <!-- Globally remove the default focus-ring adorner — interactive controls use
         :focus-visible styles instead so keyboard nav still works. -->
    <Style Selector="Control">
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <!-- ── Button base (removes SimpleTheme defaults) ─────────────────────── -->
    <Style Selector="Button">
        <Setter Property="Background"  Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Foreground"  Value="{DynamicResource TextPrimary}"/>
        <Setter Property="Padding"     Value="8,4"/>
        <Setter Property="Cursor"      Value="Hand"/>
    </Style>
    <!-- Suppress SimpleTheme's internal focus background on mouse-click focus -->
    <Style Selector="Button:focus:not(:focus-visible) /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- Toolbar button -->
    <Style Selector="Button.ToolbarButton">
        <Setter Property="FontSize"     Value="12"/>
        <Setter Property="CornerRadius" Value="3"/>
    </Style>
    <Style Selector="Button.ToolbarButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource Bg4}"/>
    </Style>
    <Style Selector="Button.ToolbarButton:pressed">
        <Setter Property="Background" Value="{DynamicResource AccentMuted}"/>
    </Style>
    <Style Selector="Button.ToolbarButton.active">
        <Setter Property="Background" Value="{DynamicResource AccentMuted}"/>
    </Style>
    <!-- The global :focus:not(:focus-visible) style sets ContentPresenter.Background=Transparent at
         StyleTrigger priority, which beats the TemplateBinding (TemplatedParent priority). This
         override restores AccentMuted for active toolbar buttons that also have mouse-click focus,
         using higher specificity to win over the global suppressor. -->
    <Style Selector="Button.ToolbarButton.active:focus:not(:focus-visible) /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentMuted}"/>
    </Style>

    <!-- LFAM 3 workflow timeline -->
    <Style Selector="Border.Lfam3WorkflowPanel">
        <Setter Property="Background"      Value="#E80D1118"/>
        <Setter Property="BorderBrush"     Value="#2a3044"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="10"/>
        <Setter Property="Padding"         Value="14,12,14,14"/>
        <Setter Property="Opacity"         Value="0.98"/>
        <Setter Property="ClipToBounds"    Value="False"/>
    </Style>
    <Style Selector="Border.Lfam3WorkflowTrack">
        <Setter Property="Background"          Value="#0A0E14"/>
        <Setter Property="BorderBrush"         Value="#1e2433"/>
        <Setter Property="BorderThickness"     Value="1"/>
        <Setter Property="CornerRadius"        Value="8"/>
        <Setter Property="Padding"             Value="10,6,10,6"/>
        <Setter Property="Height"              Value="68"/>
        <Setter Property="ClipToBounds"        Value="False"/>
    </Style>
    <Style Selector="Border.Lfam3WorkflowPhaseFloat">
        <Setter Property="Background"          Value="Transparent"/>
        <Setter Property="BorderThickness"     Value="0"/>
        <Setter Property="Padding"             Value="0"/>
        <Setter Property="ClipToBounds"        Value="False"/>
    </Style>
    <!-- Pick/Deposit overlay — sibling layer on track Panel; never inside phase block grid -->
    <Style Selector="Grid.Lfam3WorkflowPickDepositOverlay">
        <Setter Property="Background"          Value="Transparent"/>
        <Setter Property="ClipToBounds"        Value="False"/>
        <Setter Property="IsHitTestVisible"    Value="True"/>
    </Style>
    <Style Selector="Border.Lfam3WorkflowConnector">
        <Setter Property="Height"              Value="2"/>
        <Setter Property="Background"          Value="#2a3044"/>
        <Setter Property="CornerRadius"        Value="1"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="Border.Lfam3WorkflowConnector.done">
        <Setter Property="Background" Value="#59FF0D"/>
    </Style>
    <Style Selector="Border.Lfam3WorkflowSectionDivider">
        <Setter Property="Height"              Value="1"/>
        <Setter Property="Background"          Value="#252b3d"/>
        <Setter Property="Margin"              Value="0,4,0,8"/>
    </Style>
    <Style Selector="Button.Lfam3WorkflowHeaderBtn">
        <Setter Property="Background"      Value="#141820"/>
        <Setter Property="BorderBrush"     Value="#2a3044"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="6"/>
        <Setter Property="Padding"         Value="8,6"/>
        <Setter Property="Cursor"          Value="Hand"/>
    </Style>
    <Style Selector="Button.Lfam3WorkflowHeaderBtn:pointerover">
        <Setter Property="BorderBrush" Value="#59FF0D"/>
        <Setter Property="Background"  Value="#1a2030"/>
    </Style>
    <Style Selector="Button.Lfam3WorkflowStep">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderBrush"     Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment"   Value="Center"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="MinWidth"        Value="52"/>
        <Setter Property="MinHeight"       Value="52"/>
    </Style>
    <Style Selector="Button.Lfam3WorkflowStep:pointerover">
        <Setter Property="Opacity" Value="0.9"/>
    </Style>
    <Style Selector="Button.Lfam3WorkflowAddStep">
        <Setter Property="Width"            Value="24"/>
        <Setter Property="Height"           Value="24"/>
        <Setter Property="CornerRadius"     Value="12"/>
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="BorderBrush"      Value="#3a4055"/>
        <Setter Property="BorderThickness"  Value="1.5"/>
        <Setter Property="Padding"          Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment"   Value="Center"/>
        <Setter Property="Cursor"           Value="Hand"/>
    </Style>
    <Style Selector="Button.Lfam3WorkflowAddStep:pointerover">
        <Setter Property="Opacity" Value="0.85"/>
    </Style>
    <Style Selector="Button.Lfam3WorkflowAddStep.active">
        <Setter Property="BorderBrush" Value="#59FF0D"/>
        <Setter Property="Background"  Value="#141c10"/>
    </Style>
    <Style Selector="Border.Lfam3RivetAnchor">
        <Setter Property="Background"          Value="Transparent"/>
        <Setter Property="HorizontalAlignment"   Value="Center"/>
    </Style>
    <Style Selector="Grid.Lfam3WorkflowPhaseIconHost">
        <Setter Property="Width"                 Value="52"/>
        <Setter Property="Height"                Value="52"/>
        <Setter Property="HorizontalAlignment"   Value="Center"/>
        <Setter Property="VerticalAlignment"     Value="Center"/>
    </Style>
    <Style Selector="ia|Icon.Lfam3WorkflowPhaseIcon">
        <Setter Property="FontSize"              Value="22"/>
        <Setter Property="HorizontalAlignment"   Value="Center"/>
        <Setter Property="VerticalAlignment"     Value="Center"/>
    </Style>
    <Style Selector="Ellipse.Lfam3WorkflowGlow">
        <Setter Property="Width"               Value="54"/>
        <Setter Property="Height"              Value="54"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment"   Value="Center"/>
        <Setter Property="Stroke"              Value="#5059FF0D"/>
        <Setter Property="StrokeThickness"     Value="1.5"/>
        <Setter Property="Fill"                Value="Transparent"/>
    </Style>
    <Style Selector="Ellipse.Lfam3WorkflowNode">
        <Setter Property="Width"               Value="52"/>
        <Setter Property="Height"              Value="52"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment"   Value="Center"/>
        <Setter Property="StrokeThickness"     Value="1.5"/>
    </Style>
    <Style Selector="Ellipse.Lfam3WorkflowNode.pending">
        <Setter Property="Fill"        Value="#1a1f2c"/>
        <Setter Property="Stroke"      Value="#3a4055"/>
    </Style>
    <Style Selector="Ellipse.Lfam3WorkflowNode.active">
        <Setter Property="Fill"        Value="#7359FF0D"/>
        <Setter Property="Stroke"      Value="#59FF0D"/>
        <Setter Property="StrokeThickness" Value="2.5"/>
    </Style>
    <Style Selector="Ellipse.Lfam3WorkflowNode.completed">
        <Setter Property="Fill"        Value="#2B59FF0D"/>
        <Setter Property="Stroke"      Value="#59FF0D"/>
    </Style>
    <Style Selector="TextBlock.Lfam3WorkflowPhaseTitle">
        <Setter Property="FontSize"   Value="9"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="LetterSpacing" Value="1"/>
    </Style>
    <Style Selector="TextBlock.Lfam3WorkflowPhaseTitle.chip">
        <Setter Property="FontSize"            Value="9"/>
        <Setter Property="FontWeight"          Value="Bold"/>
        <Setter Property="LetterSpacing"       Value="1"/>
        <Setter Property="Foreground"          Value="#6b7280"/>
        <Setter Property="Padding"             Value="4,2"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>
    <Style Selector="TextBlock.Lfam3WorkflowPhaseTitle.chip.active">
        <Setter Property="Foreground" Value="#59FF0D"/>
    </Style>
    <Style Selector="TextBlock.Lfam3WorkflowPhaseTitle.active">
        <Setter Property="Foreground" Value="#59FF0D"/>
    </Style>
    <Style Selector="TextBlock.Lfam3WorkflowPhaseSub">
        <Setter Property="FontSize"   Value="10"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
    </Style>
    <Style Selector="Border.Lfam3WorkflowParamCard">
        <Setter Property="Background"          Value="#181c28"/>
        <Setter Property="BorderBrush"         Value="#252b3d"/>
        <Setter Property="BorderThickness"     Value="1"/>
        <Setter Property="CornerRadius"        Value="6"/>
        <Setter Property="Padding"             Value="8,6"/>
        <Setter Property="MinHeight"           Value="0"/>
        <Setter Property="VerticalAlignment"   Value="Top"/>
        <Setter Property="ClipToBounds"        Value="False"/>
    </Style>
    <Style Selector="Border.Lfam3WorkflowParamCard.active">
        <Setter Property="BorderBrush"     Value="#59FF0D"/>
        <Setter Property="Background"      Value="#1c2230"/>
    </Style>
    <Style Selector="Border.Lfam3WorkflowPhaseCard">
        <Setter Property="Background"          Value="#121820"/>
        <Setter Property="BorderBrush"         Value="#59FF0D"/>
        <Setter Property="BorderThickness"     Value="1"/>
        <Setter Property="CornerRadius"        Value="8"/>
        <Setter Property="Padding"             Value="10,8"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="MinWidth"            Value="148"/>
        <Setter Property="Margin"              Value="0"/>
    </Style>
    <Style Selector="Border.Lfam3WorkflowPhaseCard.active">
        <Setter Property="Background" Value="#141c28"/>
    </Style>
    <Style Selector="StackPanel.Lfam3WorkflowPhaseHeader">
        <Setter Property="Spacing"           Value="6"/>
        <Setter Property="Margin"            Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="Border.Lfam3WorkflowPhaseHeaderPad">
        <Setter Property="Height"              Value="46"/>
        <Setter Property="Padding"             Value="0"/>
        <Setter Property="Background"          Value="Transparent"/>
        <Setter Property="BorderThickness"     Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment"   Value="Top"/>
        <Setter Property="ClipToBounds"        Value="False"/>
    </Style>
    <Style Selector="Border.Lfam3WorkflowPhaseTrack">
        <Setter Property="Height"              Value="92"/>
        <Setter Property="MinHeight"           Value="92"/>
        <Setter Property="Padding"             Value="0"/>
        <Setter Property="Background"          Value="Transparent"/>
        <Setter Property="BorderThickness"     Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment"   Value="Bottom"/>
        <Setter Property="ClipToBounds"        Value="False"/>
    </Style>
    <Style Selector="Border.Lfam3WorkflowPhaseFold">
        <Setter Property="Height"              Value="1"/>
        <Setter Property="Background"          Value="#59FF0D"/>
        <Setter Property="BorderThickness"     Value="0"/>
        <Setter Property="Margin"              Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="Border.Lfam3WorkflowPhaseDetails">
        <Setter Property="Background"          Value="#1a2030"/>
        <Setter Property="BorderThickness"     Value="0"/>
        <Setter Property="CornerRadius"        Value="0,0,6.5,6.5"/>
        <Setter Property="Padding"             Value="10,8,10,10"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="Border.Lfam3WorkflowSeqPanel">
        <Setter Property="Background"          Value="#0E1218"/>
        <Setter Property="BorderBrush"         Value="#2a3044"/>
        <Setter Property="CornerRadius"        Value="8"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="MinWidth"            Value="168"/>
        <Setter Property="ClipToBounds"        Value="True"/>
        <Setter Property="MaxHeight"           Value="0"/>
        <Setter Property="Opacity"             Value="0"/>
        <Setter Property="Padding"             Value="0"/>
        <Setter Property="Margin"              Value="0"/>
        <Setter Property="BorderThickness"     Value="0"/>
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="MaxHeight" Duration="0:0:0.22" Easing="CubicEaseOut"/>
                <DoubleTransition Property="Opacity"   Duration="0:0:0.16" Easing="CubicEaseOut"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.Lfam3WorkflowSeqPanel.expanded">
        <Setter Property="MaxHeight"       Value="140"/>
        <Setter Property="Opacity"         Value="1"/>
        <Setter Property="Padding"         Value="10,8"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Border.Lfam3SeqPillGroup">
        <Setter Property="Background"      Value="#141820"/>
        <Setter Property="BorderBrush"     Value="#59FF0D"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="6"/>
        <Setter Property="Padding"         Value="1"/>
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.14" Easing="CubicEaseOut"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.Lfam3SeqPill">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="#9ca3af"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="12,6"/>
        <Setter Property="FontSize"        Value="10"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="MinWidth"        Value="56"/>
        <Setter Property="Cursor"          Value="Hand"/>
    </Style>
    <Style Selector="Button.Lfam3SeqPill:pointerover">
        <Setter Property="Foreground" Value="#e8eaef"/>
    </Style>
    <Style Selector="Button.Lfam3SeqPill.active">
        <Setter Property="Background"  Value="#59FF0D"/>
        <Setter Property="Foreground"  Value="#0a0f18"/>
        <Setter Property="FontWeight"  Value="Bold"/>
    </Style>
    <Style Selector="Button.Lfam3SeqPill.pick">
        <Setter Property="CornerRadius" Value="6,0,0,6"/>
    </Style>
    <Style Selector="Button.Lfam3SeqPill.deposit">
        <Setter Property="CornerRadius" Value="0,6,6,0"/>
    </Style>
    <Style Selector="Button.Lfam3SeqPill.deposit.active">
        <Setter Property="Background" Value="#3d8f5a"/>
    </Style>
    <Style Selector="Button.Lfam3ToolChangePick">
        <Setter Property="Background"      Value="#59FF0D"/>
        <Setter Property="Foreground"      Value="#0a0f18"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush"     Value="#3d8f08"/>
        <Setter Property="CornerRadius"    Value="6"/>
        <Setter Property="Padding"         Value="12,8"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="FontWeight"      Value="Bold"/>
        <Setter Property="MinWidth"        Value="92"/>
        <Setter Property="MinHeight"       Value="32"/>
        <Setter Property="Cursor"          Value="Hand"/>
    </Style>
    <Style Selector="Button.Lfam3ToolChangePick:pointerover">
        <Setter Property="Opacity" Value="0.9"/>
    </Style>
    <Style Selector="Button.Lfam3ToolChangePick:disabled">
        <Setter Property="Opacity" Value="0.35"/>
    </Style>
    <Style Selector="Button.Lfam3ToolChangePick.active">
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush"     Value="#ffffff"/>
    </Style>
    <Style Selector="Button.Lfam3ToolChangeDeposit">
        <Setter Property="Background"      Value="#c8f5d4"/>
        <Setter Property="Foreground"      Value="#0a0f18"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush"     Value="#5a9e72"/>
        <Setter Property="CornerRadius"    Value="6"/>
        <Setter Property="Padding"         Value="12,8"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="FontWeight"      Value="Bold"/>
        <Setter Property="MinWidth"        Value="92"/>
        <Setter Property="MinHeight"       Value="32"/>
        <Setter Property="Cursor"          Value="Hand"/>
    </Style>
    <Style Selector="Button.Lfam3ToolChangeDeposit:pointerover">
        <Setter Property="Opacity" Value="0.9"/>
    </Style>
    <Style Selector="Button.Lfam3ToolChangeDeposit:disabled">
        <Setter Property="Opacity" Value="0.35"/>
    </Style>
    <Style Selector="Button.Lfam3ToolChangeDeposit.active">
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush"     Value="#ffffff"/>
    </Style>

    <!-- LFAM 3 tool-change sequence panel (MassiveCONNECT-style) -->
    <Style Selector="Button.Lfam3SeqBtn">
        <Setter Property="Background"      Value="#1f293780"/>
        <Setter Property="Foreground"      Value="#6b7280"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush"     Value="#252b3d"/>
        <Setter Property="CornerRadius"    Value="6,0,0,6"/>
        <Setter Property="Padding"         Value="10,8"/>
        <Setter Property="FontSize"        Value="11"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="MinHeight"       Value="32"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.Lfam3SeqBtn:pointerover">
        <Setter Property="Foreground"  Value="#e8eaef"/>
        <Setter Property="BorderBrush" Value="#59FF0D"/>
    </Style>
    <Style Selector="Button.Lfam3SeqBtn:disabled">
        <Setter Property="Opacity" Value="0.35"/>
    </Style>
    <Style Selector="Button.Lfam3SeqBtn.active">
        <Setter Property="Background"  Value="#59FF0D"/>
        <Setter Property="Foreground"  Value="#0a0f18"/>
        <Setter Property="BorderBrush" Value="#59FF0D"/>
        <Setter Property="FontWeight"  Value="Bold"/>
    </Style>
    <Style Selector="Button.Lfam3SeqBtn.deposit">
        <Setter Property="CornerRadius" Value="0"/>
    </Style>
    <Style Selector="Button.Lfam3SeqBtn.deposit.active">
        <Setter Property="Background"  Value="#c8f5d4"/>
        <Setter Property="BorderBrush" Value="#5a9e72"/>
    </Style>
    <Style Selector="Button.Lfam3SeqBtn.Lfam3SeqBtnFlank">
        <Setter Property="MinWidth"  Value="54"/>
        <Setter Property="Padding"   Value="8,6"/>
        <Setter Property="FontSize"  Value="10"/>
    </Style>
    <Style Selector="Button.Lfam3SeqBtn.pick.Lfam3SeqBtnFlank">
        <Setter Property="CornerRadius" Value="6,0,0,6"/>
    </Style>
    <Style Selector="Button.Lfam3SeqBtn.deposit.Lfam3SeqBtnFlank">
        <Setter Property="CornerRadius" Value="0"/>
    </Style>
    <Style Selector="Button.Lfam3SeqRunCaret">
        <Setter Property="Background"      Value="#1f293780"/>
        <Setter Property="Foreground"      Value="#f59e0b"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush"     Value="#252b3d"/>
        <Setter Property="CornerRadius"    Value="0,6,6,0"/>
        <Setter Property="Padding"         Value="0"/>
        <Setter Property="Width"           Value="26"/>
        <Setter Property="MinHeight"       Value="32"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
    </Style>
    <Style Selector="Button.Lfam3SeqRunCaret:pointerover">
        <Setter Property="Background"  Value="#f59e0b2e"/>
        <Setter Property="BorderBrush" Value="#f59e0b"/>
    </Style>
    <Style Selector="Button.Lfam3SeqRunCaret:disabled">
        <Setter Property="Opacity" Value="0.4"/>
    </Style>
    <Style Selector="Button.Lfam3SeqPlayBtn">
        <Setter Property="Background"      Value="#1f293799"/>
        <Setter Property="Foreground"      Value="#e8eaef"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush"     Value="#252b3d"/>
        <Setter Property="CornerRadius"    Value="6"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
    </Style>
    <Style Selector="Button.Lfam3SeqPlayBtn:pointerover">
        <Setter Property="BorderBrush" Value="#59FF0D"/>
    </Style>
    <Style Selector="Button.Lfam3SeqCollapseBtn">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
        <Setter Property="Opacity"         Value="0.75"/>
    </Style>
    <Style Selector="Button.Lfam3SeqCollapseBtn:pointerover">
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="Background" Value="#59FF0D18"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>
    <Style Selector="Slider.Lfam3SeqScrub">
        <Setter Property="MinHeight" Value="12"/>
    </Style>
    <Style Selector="Border.SeqWaypointEditorPanel">
        <Setter Property="Background"      Value="#E6101820"/>
        <Setter Property="BorderBrush"     Value="#2a2f42"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="8"/>
        <Setter Property="Padding"         Value="14,12"/>
        <Setter Property="Opacity"         Value="0.98"/>
    </Style>
    <Style Selector="Button.SeqWaypointEditorClose">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground"      Value="#9ca3af"/>
        <Setter Property="Cursor"          Value="Hand"/>
    </Style>
    <Style Selector="Button.SeqWaypointEditorClose:pointerover">
        <Setter Property="Foreground" Value="#f3f4f6"/>
    </Style>
    <Style Selector="Button.SeqWaypointEditorSecondary">
        <Setter Property="Background"      Value="#1f2937"/>
        <Setter Property="Foreground"      Value="#e8eaef"/>
        <Setter Property="BorderBrush"     Value="#374151"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="6"/>
        <Setter Property="Padding"         Value="10,8"/>
        <Setter Property="FontSize"        Value="11"/>
        <Setter Property="Cursor"          Value="Hand"/>
    </Style>
    <Style Selector="Button.SeqWaypointEditorSecondary:pointerover">
        <Setter Property="BorderBrush" Value="#59FF0D"/>
    </Style>
    <Style Selector="Button.SeqWaypointEditorSave">
        <Setter Property="Background"      Value="#59FF0D"/>
        <Setter Property="Foreground"      Value="#0a0f18"/>
        <Setter Property="BorderBrush"     Value="#59FF0D"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="6"/>
        <Setter Property="Padding"         Value="10,8"/>
        <Setter Property="FontSize"        Value="11"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Cursor"          Value="Hand"/>
    </Style>
    <Style Selector="Button.SeqWaypointEditorSave:disabled">
        <Setter Property="Background"  Value="#374151"/>
        <Setter Property="Foreground"  Value="#6b7280"/>
        <Setter Property="BorderBrush" Value="#374151"/>
    </Style>
    <Style Selector="TextBlock.Lfam3SeqLegendLin">
        <Setter Property="Foreground" Value="#6b7280"/>
    </Style>
    <Style Selector="TextBlock.Lfam3SeqLegendLin.dash">
        <Setter Property="Foreground" Value="#59FF0D"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>
    <Style Selector="TextBlock.Lfam3SeqLegendPtp">
        <Setter Property="Foreground" Value="#6b7280"/>
    </Style>
    <Style Selector="TextBlock.Lfam3SeqLegendPtp.dash">
        <Setter Property="Foreground" Value="#818cf8"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- LFAM 3 live I/O monitor -->
    <Style Selector="Border.Lfam3WorkflowPhaseStrip">
        <Setter Property="Background"          Value="#181c28"/>
        <Setter Property="BorderBrush"         Value="#252b3d"/>
        <Setter Property="BorderThickness"     Value="1"/>
        <Setter Property="CornerRadius"        Value="6"/>
        <Setter Property="Padding"             Value="8,6"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="Button.Lfam3LiveIoToggleBar">
        <Setter Property="Background"      Value="#181c28"/>
        <Setter Property="BorderBrush"     Value="#252b3d"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="6"/>
        <Setter Property="Padding"         Value="8,5"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
    </Style>
    <Style Selector="Button.Lfam3LiveIoToggleBar.expanded">
        <Setter Property="BorderBrush" Value="#59FF0D"/>
        <Setter Property="Background"  Value="#1c2230"/>
    </Style>
    <Style Selector="Button.Lfam3LiveIoToggleBar:pointerover">
        <Setter Property="Background"  Value="#1c2230"/>
        <Setter Property="BorderBrush" Value="#3a4055"/>
    </Style>
    <Style Selector="Border.Lfam3LiveIoPanel">
        <Setter Property="Background"      Value="#D0131720"/>
        <Setter Property="BorderBrush"     Value="#2a2f42"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="8"/>
        <Setter Property="Padding"         Value="8"/>
    </Style>
    <Style Selector="Border.Lfam3LiveIoPanel.nested">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="0"/>
    </Style>
    <Style Selector="Border.Lfam3LiveIoSection">
        <Setter Property="Background"      Value="#181c28"/>
        <Setter Property="BorderBrush"     Value="#252b3d"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="6"/>
        <Setter Property="Padding"         Value="8,6"/>
        <Setter Property="ClipToBounds"    Value="False"/>
        <Setter Property="MinWidth"        Value="220"/>
        <Setter Property="MaxWidth"        Value="300"/>
    </Style>
    <Style Selector="Border.Lfam3LiveIoSection.split-io">
        <Setter Property="MinWidth"        Value="520"/>
        <Setter Property="MaxWidth"        Value="9999"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="Border.Lfam3LiveIoSection.robot-triple">
        <Setter Property="MinWidth"        Value="720"/>
    </Style>
    <Style Selector="Border.Lfam3LiveIoPoseColumn">
        <Setter Property="Background"      Value="#12161f"/>
        <Setter Property="BorderBrush"     Value="#252b3d"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="5"/>
        <Setter Property="Padding"         Value="8,6"/>
        <Setter Property="MinWidth"        Value="156"/>
        <Setter Property="MaxWidth"        Value="168"/>
    </Style>
    <Style Selector="Border.Lfam3LiveIoPoseGroup">
        <Setter Property="Background"      Value="#0d1018"/>
        <Setter Property="BorderBrush"     Value="#1e2433"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="4"/>
        <Setter Property="Padding"         Value="6,5"/>
    </Style>
    <Style Selector="TextBlock.Lfam3LiveIoPoseGroupTitle">
        <Setter Property="FontSize"        Value="8"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Foreground"      Value="#6a7a94"/>
        <Setter Property="LetterSpacing"   Value="0.6"/>
        <Setter Property="Margin"          Value="0,0,0,4"/>
    </Style>
    <Style Selector="TextBlock.Lfam3LiveIoPoseLabel">
        <Setter Property="FontSize"        Value="9"/>
        <Setter Property="Foreground"      Value="#6a7a94"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="TextBlock.Lfam3LiveIoPoseValue">
        <Setter Property="FontSize"        Value="10"/>
        <Setter Property="FontFamily"      Value="Consolas,Courier New,monospace"/>
        <Setter Property="Foreground"      Value="#e8ecf4"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="TextBlock.Lfam3LiveIoPoseValue.muted">
        <Setter Property="Foreground"      Value="#4a5568"/>
    </Style>
    <Style Selector="Border.Lfam3LiveIoPoseLivePill">
        <Setter Property="Background"      Value="#1a2e14"/>
        <Setter Property="BorderBrush"     Value="#59FF0D"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="8"/>
        <Setter Property="Padding"         Value="6,2"/>
    </Style>
    <Style Selector="Border.Lfam3LiveIoColumnDivider">
        <Setter Property="Width"           Value="1"/>
        <Setter Property="Background"      Value="#2a2f42"/>
        <Setter Property="Margin"          Value="0,2"/>
    </Style>
    <Style Selector="Border.Lfam3LiveIoSection.pending">
        <Setter Property="Opacity" Value="0.55"/>
    </Style>
    <Style Selector="TextBlock.Lfam3LiveIoSectionTitle">
        <Setter Property="FontSize"   Value="10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#59FF0D"/>
        <Setter Property="LetterSpacing" Value="0.8"/>
    </Style>
    <Style Selector="Border.Lfam3LiveIoRow">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Padding"         Value="2,1"/>
    </Style>
    <Style Selector="Ellipse.Lfam3LiveIoDot">
        <Setter Property="Width"            Value="10"/>
        <Setter Property="Height"           Value="10"/>
        <Setter Property="StrokeThickness"  Value="1"/>
    </Style>
    <Style Selector="Ellipse.Lfam3LiveIoDot.inactive">
        <Setter Property="Fill"        Value="#2a3040"/>
        <Setter Property="Stroke"      Value="#3a4055"/>
    </Style>
    <Style Selector="Ellipse.Lfam3LiveIoDot.active">
        <Setter Property="Fill"        Value="#59FF0D"/>
        <Setter Property="Stroke"      Value="#59FF0D"/>
    </Style>
    <Style Selector="Ellipse.Lfam3LiveIoDot.warning">
        <Setter Property="Fill"        Value="#f0c040"/>
        <Setter Property="Stroke"      Value="#f0c040"/>
    </Style>
    <Style Selector="Ellipse.Lfam3LiveIoDot.fault">
        <Setter Property="Fill"        Value="#f05252"/>
        <Setter Property="Stroke"      Value="#f05252"/>
    </Style>
    <Style Selector="Button.Lfam3LiveIoToggle">
        <Setter Property="Background"      Value="#1a2030"/>
        <Setter Property="BorderBrush"     Value="#3a4055"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground"      Value="{DynamicResource TextSecondary}"/>
        <Setter Property="CornerRadius"    Value="4"/>
        <Setter Property="Cursor"          Value="Hand"/>
    </Style>
    <Style Selector="Button.Lfam3LiveIoToggle:pointerover">
        <Setter Property="BorderBrush" Value="#59FF0D"/>
    </Style>

    <!-- Tab button -->
    <Style Selector="Button.TabButton">
        <Setter Property="Foreground"  Value="{DynamicResource TextSecondary}"/>
        <Setter Property="FontSize"    Value="11"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="Padding"     Value="12,6"/>
    </Style>
    <Style Selector="Button.TabButton:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    </Style>
    <Style Selector="Button.TabButton.active">
        <Setter Property="Foreground"       Value="{DynamicResource TextPrimary}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource Accent}"/>
        <Setter Property="BorderThickness"  Value="0,0,0,2"/>
    </Style>

    <!-- Secondary action button — lighter than PrimaryButton for de-emphasized actions -->
    <Style Selector="Button.SecondaryButton">
        <Setter Property="Background"   Value="{DynamicResource Bg3}"/>
        <Setter Property="Foreground"   Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontSize"     Value="12"/>
        <Setter Property="FontWeight"   Value="Normal"/>
        <Setter Property="Padding"      Value="12,6"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="BorderBrush"  Value="{DynamicResource Border1}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Button.SecondaryButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource Bg4}"/>
    </Style>
    <Style Selector="Button.SecondaryButton:pressed">
        <Setter Property="Background" Value="{DynamicResource Bg3}"/>
    </Style>

    <!-- Primary action button -->
    <Style Selector="Button.PrimaryButton">
        <Setter Property="Background"   Value="{DynamicResource Accent}"/>
        <Setter Property="Foreground"   Value="#ffffff"/>
        <Setter Property="FontSize"     Value="13"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
        <Setter Property="Padding"      Value="16,8"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>
    <Style Selector="Button.PrimaryButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource AccentHover}"/>
    </Style>
    <Style Selector="Button.PrimaryButton:pressed">
        <Setter Property="Background" Value="{DynamicResource Accent}"/>
    </Style>

    <!-- Shader sphere button — circular button whose Background IS the sphere preview.
         No content text; a 2px border ring shows hover/active state. -->
    <Style Selector="Button.ShaderSphereBtn">
        <Setter Property="Width"           Value="44"/>
        <Setter Property="Height"          Value="44"/>
        <Setter Property="Padding"         Value="0"/>
        <Setter Property="CornerRadius"    Value="22"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush"     Value="Transparent"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border CornerRadius="{TemplateBinding CornerRadius}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"/>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Button.ShaderSphereBtn:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource Border2}"/>
    </Style>
    <Style Selector="Button.ShaderSphereBtn.active">
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
    </Style>

    <!-- Nav preset button (Preferences window) -->
    <Style Selector="Button.NavPresetBtn">
        <Setter Property="FontSize"     Value="12"/>
        <Setter Property="Padding"      Value="10,7"/>
        <Setter Property="CornerRadius" Value="3"/>
    </Style>
    <Style Selector="Button.NavPresetBtn:pointerover">
        <Setter Property="Background" Value="{DynamicResource Bg4}"/>
    </Style>
    <Style Selector="Button.NavPresetBtn:pressed">
        <Setter Property="Background" Value="{DynamicResource AccentMuted}"/>
    </Style>

    <!-- ── TextBox ────────────────────────────────────────────────────────── -->
    <Style Selector="TextBox.PanelTextBox">
        <Setter Property="Background"      Value="{DynamicResource Bg4}"/>
        <Setter Property="Foreground"      Value="{DynamicResource TextPrimary}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource Border2}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="6,3"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="CaretBrush"      Value="{DynamicResource Accent}"/>
        <Setter Property="SelectionBrush"  Value="{DynamicResource AccentMuted}"/>
    </Style>

    <!-- ── ComboBox ───────────────────────────────────────────────────────── -->
    <Style Selector="ComboBox">
        <Setter Property="Background"        Value="{DynamicResource Bg2}"/>
        <Setter Property="Foreground"        Value="{DynamicResource Accent}"/>
        <Setter Property="BorderBrush"       Value="{DynamicResource Border2}"/>
        <Setter Property="BorderThickness"   Value="1"/>
        <Setter Property="Padding"           Value="6,4"/>
        <Setter Property="CornerRadius"      Value="4"/>
        <Setter Property="MaxDropDownHeight" Value="220"/>
        <Setter Property="Cursor"            Value="Hand"/>
    </Style>
    <!-- Template-targeting beats ControlTheme's ThemeBorderHighBrush override on hover -->
    <Style Selector="ComboBox:pointerover /template/ Border#border">
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
    </Style>
    <Style Selector="ComboBox:focus-visible /template/ Border#border">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentHover}"/>
    </Style>

    <Style Selector="ComboBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
        <Setter Property="Padding"    Value="8,6"/>
        <Setter Property="Cursor"     Value="Hand"/>
    </Style>
    <Style Selector="ComboBoxItem:pointerover">
        <Setter Property="Background" Value="{DynamicResource Bg4}"/>
    </Style>
    <!-- Override the template-level selection highlight (beats SimpleTheme's HighlightBrush) -->
    <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentMuted}"/>
    </Style>
    <Style Selector="ComboBoxItem:selected">
        <Setter Property="Foreground" Value="{DynamicResource AccentHover}"/>
    </Style>
    <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Bg4}"/>
    </Style>

    <!-- ── CheckBox ───────────────────────────────────────────────────────── -->
    <!-- Set on CheckBox itself so {TemplateBinding} picks up the values -->
    <Style Selector="CheckBox">
        <Setter Property="Background"      Value="{DynamicResource Bg4}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource TextMuted}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="CornerRadius"    Value="4"/>
    </Style>
    <!-- StyleTrigger priority overrides the ControlTheme's pointerover setter -->
    <Style Selector="CheckBox:pointerover /template/ Border#border">
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
    </Style>

    <!-- ── ToolTip ────────────────────────────────────────────────────────── -->
    <Style Selector="ToolTip">
        <Setter Property="Background"      Value="{DynamicResource Bg3}"/>
        <Setter Property="Foreground"      Value="{DynamicResource TextPrimary}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource Border2}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="6,4"/>
        <Setter Property="FontSize"        Value="11"/>
    </Style>

    <!-- ── ColorPicker ──────────────────────────────────────────────────────── -->
    <!-- ColorPicker is a DropDownButton wrapping a color swatch + flyout ColorView. -->
    <Style Selector="ColorPicker">
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Height"       Value="28"/>
    </Style>
    <!-- Theme the outer DropDownButton to match Obsidian palette -->
    <Style Selector="ColorPicker /template/ DropDownButton">
        <Setter Property="Background"      Value="{DynamicResource Bg3}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource Border2}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="6"/>
    </Style>
    <!-- Target the inner Border that actually renders the button chrome -->
    <Style Selector="ColorPicker /template/ DropDownButton /template/ Border#border">
        <Setter Property="Background"  Value="{DynamicResource Bg3}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Border2}"/>
    </Style>
    <Style Selector="ColorPicker /template/ DropDownButton:pointerover /template/ Border#border">
        <Setter Property="Background"  Value="{DynamicResource Bg4}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
    </Style>
    <Style Selector="ColorPicker /template/ DropDownButton:pressed /template/ Border#border">
        <Setter Property="Background" Value="{DynamicResource AccentMuted}"/>
    </Style>

    <!-- ── Scrubber label input ─────────────────────────────────────────────── -->
    <!-- Inline move-number input in the floating scrubber label.
         Invisible until hovered/focused so it reads as a normal label at a glance. -->
    <Style Selector="TextBox.ScrubInput">
        <Setter Property="Background"                 Value="Transparent"/>
        <Setter Property="BorderBrush"                Value="Transparent"/>
        <Setter Property="BorderThickness"            Value="0,0,0,1"/>
        <Setter Property="Padding"                    Value="2,0"/>
        <Setter Property="FontSize"                   Value="10"/>
        <Setter Property="FontFamily"                 Value="Consolas, Courier New, monospace"/>
        <Setter Property="Foreground"                 Value="{DynamicResource TextPrimary}"/>
        <Setter Property="CaretBrush"                 Value="{DynamicResource Accent}"/>
        <Setter Property="SelectionBrush"             Value="{DynamicResource AccentMuted}"/>
        <Setter Property="Width"                      Value="36"/>
        <Setter Property="MinWidth"                   Value="0"/>
        <Setter Property="MinHeight"                  Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Right"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
    </Style>
    <!-- Template-level override: keep the inner border transparent by default -->
    <Style Selector="TextBox.ScrubInput /template/ Border">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderBrush"     Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>
    <Style Selector="TextBox.ScrubInput:pointerover /template/ Border">
        <Setter Property="BorderBrush" Value="{DynamicResource Border2}"/>
    </Style>
    <Style Selector="TextBox.ScrubInput:focus-within /template/ Border">
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
    </Style>

    <!-- ── Collapsible section expander ─────────────────────────────────────── -->
    <Style Selector="Expander.SectionExpander">
        <Setter Property="HorizontalAlignment"        Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Padding"                    Value="0"/>
        <Setter Property="Template">
            <ControlTemplate>
                <StackPanel>
                    <ToggleButton Name="PART_toggle"
                                  IsChecked="{TemplateBinding IsExpanded, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Padding="8,8,8,6"
                                  Cursor="Hand">
                        <Grid ColumnDefinitions="*,14">
                            <TextBlock Grid.Column="0"
                                       Text="{TemplateBinding Header}"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Name="Chevron"
                                       Grid.Column="1"
                                       Text="›"
                                       Foreground="{DynamicResource TextMuted}"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       RenderTransformOrigin="50%,50%"/>
                        </Grid>
                    </ToggleButton>
                    <Border Height="1" Background="{DynamicResource Border1}" Margin="8,0,8,0"/>
                    <ContentPresenter Name="PART_ContentPresenter"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      IsVisible="{Binding #PART_toggle.IsChecked}"/>
                </StackPanel>
            </ControlTemplate>
        </Setter>
    </Style>
    <!-- Chevron: right (0°) when collapsed, down (90°) when expanded -->
    <Style Selector="Expander.SectionExpander /template/ TextBlock#Chevron">
        <Setter Property="RenderTransform"><RotateTransform Angle="90"/></Setter>
    </Style>
    <Style Selector="Expander.SectionExpander[IsExpanded=False] /template/ TextBlock#Chevron">
        <Setter Property="RenderTransform"><RotateTransform Angle="0"/></Setter>
    </Style>
    <!-- Suppress ToggleButton default hover/checked/pressed backgrounds -->
    <Style Selector="Expander.SectionExpander /template/ ToggleButton#PART_toggle /template/ Border">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Expander.SectionExpander /template/ ToggleButton#PART_toggle:pointerover /template/ Border">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Expander.SectionExpander /template/ ToggleButton#PART_toggle:checked /template/ Border">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Expander.SectionExpander /template/ ToggleButton#PART_toggle:pressed /template/ Border">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- ── Scrubber slider ───────────────────────────────────────────────────── -->
    <Style Selector="Slider.ScrubSlider">
        <Setter Property="MinHeight" Value="12"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Track Name="PART_Track"
                       Minimum="{TemplateBinding Minimum}"
                       Maximum="{TemplateBinding Maximum}"
                       Value="{TemplateBinding Value, Mode=TwoWay}"
                       IsDirectionReversed="{TemplateBinding IsDirectionReversed}"
                       Orientation="Horizontal">
                    <Track.DecreaseButton>
                        <RepeatButton Focusable="False">
                            <RepeatButton.Template>
                                <ControlTemplate>
                                    <Border Height="6" VerticalAlignment="Center"
                                            Background="{DynamicResource Accent}"
                                            CornerRadius="2,0,0,2"/>
                                </ControlTemplate>
                            </RepeatButton.Template>
                        </RepeatButton>
                    </Track.DecreaseButton>
                    <Track.Thumb>
                        <Thumb Width="12" Height="12" Focusable="False">
                            <Thumb.Template>
                                <ControlTemplate>
                                    <Ellipse Width="12" Height="12"
                                             Fill="{DynamicResource Accent}"/>
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </Track.Thumb>
                    <Track.IncreaseButton>
                        <RepeatButton Focusable="False">
                            <RepeatButton.Template>
                                <ControlTemplate>
                                    <Border Height="6" VerticalAlignment="Center"
                                            Background="{DynamicResource Border2}"
                                            CornerRadius="0,2,2,0"/>
                                </ControlTemplate>
                            </RepeatButton.Template>
                        </RepeatButton>
                    </Track.IncreaseButton>
                </Track>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Outliner row selection (global — local Border.Styles miss class bindings in nested templates) -->
    <Style Selector="Border.outlinerRowSelected">
        <Setter Property="Background" Value="{DynamicResource AccentMuted}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Border.outlinerRowSelected TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

</Styles>
